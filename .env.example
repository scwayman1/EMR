# ---- Core ----
NODE_ENV=development

# ---- Database (Supabase Postgres) ----
# Two URLs required. Both come from the Supabase dashboard \u2192 Project
# Settings \u2192 Database \u2192 "Connect" \u2192 ORMs \u2192 Prisma. Copy both verbatim.
#
# DATABASE_URL \u2014 pooler (transaction mode, port 6543). Runtime app traffic.
# DIRECT_URL   \u2014 direct connection (port 5432). `prisma migrate` / `studio`.
#
# In the string, `[YOUR-PASSWORD]` is your Supabase database password
# (Project Settings \u2192 Database \u2192 "Database password").
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ---- Session ----
# Must be at least 32 characters. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-long-random-secret-at-least-32-chars

# ---- Agent harness ----
# Which model client to use. "stub" for local dev, "claude" for real calls.
AGENT_MODEL_CLIENT=stub
# Optional: API key for the Claude model client.
ANTHROPIC_API_KEY=

# ---- Object storage (documents) ----
# V1 uses Supabase Storage for document uploads.
# Create a project at https://supabase.com and a private bucket
# named "documents" (or whatever STORAGE_BUCKET is set to below).
SUPABASE_URL=
# Service-role key \u2014 server-only; NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_BUCKET=documents
