# ---- Core ----
NODE_ENV=development

# ---- Database ----
# Postgres connection string. On Render, this is supplied by the managed DB.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emr

# ---- Authentication ----
# Which auth provider to use.
#   "iron-session" (default) — legacy custom auth with bcrypt passwords
#   "clerk" — Clerk-managed auth (HIPAA-ready with Business plan + BAA)
AUTH_PROVIDER=iron-session

# --- iron-session (required when AUTH_PROVIDER=iron-session) ---
# Must be at least 32 characters. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-long-random-secret-at-least-32-chars

# --- Clerk (required when AUTH_PROVIDER=clerk) ---
# Get these from clerk.com → Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# From Clerk Dashboard → Webhooks → Endpoint → Signing Secret
# (create the endpoint at https://<your-domain>/api/webhooks/clerk
#  and subscribe to user.created, user.updated, user.deleted)
CLERK_WEBHOOK_SECRET=
# Tell Clerk where to redirect after sign-in / sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/portal
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/portal

# ---- Agent harness ----
# Which model client to use. "stub" for local dev / CI (deterministic, no
# network). "openrouter" for real LLM calls via OpenRouter.
AGENT_MODEL_CLIENT=stub

# OpenRouter configuration — required when AGENT_MODEL_CLIENT=openrouter.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional. Any model slug supported by OpenRouter. Defaults to Claude Sonnet 4.5.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Optional. Used for OpenRouter attribution headers (shows up in your dashboard).
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Leafjourney

# ---- Visit dictation / transcription ----
# Which speech-to-text provider to use for voice-chart recordings.
#   "simulated" (default)    — no network calls; voice-chart uses a
#                              hardcoded demo transcript. Good for CI
#                              and local dev without API keys.
#   "openai-whisper"         — POSTs the recording to OpenAI Whisper
#                              (/v1/audio/transcriptions, whisper-1,
#                              verbose_json). Requires OPENAI_API_KEY.
TRANSCRIPTION_PROVIDER=simulated

# OpenAI key, used when TRANSCRIPTION_PROVIDER=openai-whisper.
# Whisper's 25 MB payload cap covers ~25 min of typical voice audio.
# Segment-level timestamps are returned; speaker diarization is NOT —
# every segment comes back as speaker="unknown" and the extraction
# prompt handles unlabeled turns. Swap provider for real diarization.
OPENAI_API_KEY=

# ---- Object storage (Supabase Storage for documents) ----
# Create a private bucket named "documents" in your Supabase project.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_BUCKET=documents

# ---- Linear integration ----
# Personal API key from Linear (Settings -> API -> Personal API keys).
# Used by internal tooling to fetch issue specs + pinned briefing comments.
LINEAR_API_KEY=
