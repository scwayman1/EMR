# ---- Core ----
NODE_ENV=development

# ---- Database ----
# Postgres connection string. On Render, this is supplied by the managed DB.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emr

# ---- Session ----
# Must be at least 32 characters. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-long-random-secret-at-least-32-chars

# ---- Agent harness ----
# Which model client to use. "stub" for local dev / CI (deterministic, no
# network). "openrouter" for real LLM calls via OpenRouter.
AGENT_MODEL_CLIENT=stub

# OpenRouter configuration — required when AGENT_MODEL_CLIENT=openrouter.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional. Any model slug supported by OpenRouter. Defaults to Claude Sonnet 4.5.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Optional. Used for OpenRouter attribution headers (shows up in your dashboard).
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Leafjourney

# ---- Object storage (documents) ----
# V1 uses signed URLs; these are placeholders for when real storage is wired.
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
