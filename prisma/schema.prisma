// Only the VendorApplication model addition is shown here for brevity.
// See prisma/migrations/20260509000000_add_vendor_application/migration.sql
// for the authoritative DDL.

// --------------------------------------------------------------
// Leafmart — Vendor Applications
// --------------------------------------------------------------

model VendorApplication {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  companyName  String
  contactName  String
  email        String
  phone        String?
  website      String?
  productTypes Json
  hasCoa       String
  description  String
  ip           String?

  @@index([email])
  @@index([createdAt])
}
