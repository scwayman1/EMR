  patient  Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([campaignId, patientId])
  @@index([campaignId, status])
}

// --------------------------------------------------------------
// HIPAA voicemail with transcript (EMR-146)
//
// Voicemails sit on top of an inbound CallLog (channel='phone',
// status='missed'). The recording reference points at object storage;
// the raw transcript is encrypted at rest with the same envelope used
// for provider-to-provider message bodies. Only the redacted summary
