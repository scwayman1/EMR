// --------------------------------------------------------------
// Agentic Memory Harness
// --------------------------------------------------------------
// The four models below give the agent fleet a persistent, evolving
// understanding of each patient and of its own performance. This is the
// "next-level harness" layer:
//
//   PatientMemory       — the soft, narrative, evolving understanding of
//                         a specific person. Preferences, trajectory,
//                         context, what's working. Every agent reads
//                         from it before drafting; every agent writes to
//                         it when it learns something new.
//
//   ClinicalObservation — structured insights an agent notices: symptom
//                         trends, medication responses, red flags,
//                         emotional shifts. Each one is evidence-backed
//                         and can be acknowledged by the physician.
//
//   AgentReasoning      — per-job reasoning trace. Every agent output
//                         gets an explain-why record the physician can
//                         click into. No more black-box drafts.
//
//   AgentFeedback       — captures approve / edit / reject signals on
//                         every agent output. Aggregated over time this
//                         is how we measure (and eventually tune) each
//                         agent's clinical fit with the physician.
//
// These are the spine of clinical memory. See HANDOFF.md at the repo
// root for the design rationale.
// --------------------------------------------------------------

enum MemoryKind {
  preference // what the patient wants / what helps them feel heard
  observation // something we've noticed about them
  trajectory // how something is trending over time
  relationship // who's in their life (family, other providers)
  context // background that informs care
  milestone // key moments worth remembering
  working // an intervention that is currently helping
  not_working // something that was tried and didn't help
  concern // an ongoing worry the physician should keep front of mind
}

model PatientMemory {
  id             String     @id @default(cuid())
  patientId      String
  kind           MemoryKind
  /// The actual memory, written as narrative prose.
  /// e.g. "Prefers email over phone. Gets anxious when multiple prescriptions
  /// are added at once and feels more in control with single-change visits."
  content        String
  /// 0-1. How confident we are this memory is accurate + still valid.
  confidence     Float      @default(0.8)
  /// Short structured tags for quick filtering. e.g. ["sleep", "pain", "anxiety"]
  tags           String[]   @default([])
  /// Who recorded this memory.
  source         String // agent name or user id
  sourceKind     String // "agent" | "user"
  /// When this memory became valid.
  validFrom      DateTime   @default(now())
  /// When this memory stopped being valid (null = still valid).
  validUntil     DateTime?
  /// If a newer memory replaced this one, link to it.
  supersededById String?
  metadata       Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  patient      Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  supersededBy PatientMemory?  @relation("Supersession", fields: [supersededById], references: [id])
  supersedes   PatientMemory[] @relation("Supersession")

  @@index([patientId, kind, validUntil])
  @@index([patientId, createdAt])
}

enum ObservationSeverity {
  info
  notable
  concern
  urgent
}

enum ObservationCategory {
  symptom_trend
  medication_response
  adherence
  emotional_state
  red_flag
  positive_signal
  side_effect
  lifestyle_shift
  engagement
  other
}

model ClinicalObservation {
  id              String              @id @default(cuid())
  patientId       String
  /// Who observed this — agent name or user id.
  observedBy      String
  observedByKind  String // "agent" | "user"
  category        ObservationCategory
  severity        ObservationSeverity @default(info)
  /// 1-2 sentence human-readable summary of what was noticed.
  /// e.g. "Pain scores trended from 8 → 4 over the last 3 weeks of CBD:THC 1:1."
  summary         String
  /// Structured references to the data that supports this observation.
  /// e.g. { "messageIds": ["..."], "outcomeLogIds": ["..."], "noteIds": ["..."] }
  evidence        Json                @default("{}")
  /// Optional nudge: what the physician could consider doing.
  actionSuggested String?
  /// Acknowledged by the physician (click to dismiss / mark-as-seen).
  acknowledgedBy  String?
  acknowledgedAt  DateTime?
  /// When this observation stops being relevant (e.g. resolved).
  resolvedAt      DateTime?
  metadata        Json?
  createdAt       DateTime            @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, acknowledgedAt])
  @@index([patientId, category, createdAt])
  @@index([patientId, severity, createdAt])
}

model AgentReasoning {
  id           String   @id @default(cuid())
  /// Links back to the AgentJob that produced this output (if one exists).
  /// Not a hard FK — some agent calls happen outside the job queue (inline
  /// refine/dictate actions) and still want to record reasoning.
  agentJobId   String?
  agentName    String
  agentVersion String
  /// Structured steps, in order. Each step:
  /// { step: "load patient context", input: {...}, output: {...}, durationMs: number }
  steps        Json     @default("[]")
  /// References to the data sources the agent consulted.
  /// e.g. { "memories": [...ids], "notes": [...ids], "outcomeLogs": [...ids] }
  sources      Json     @default("{}")
  /// Alternatives the agent considered but did not choose.
  /// Useful for the "why this draft not that one" surface.
  alternatives Json?
  /// 0-1 self-reported confidence in the final output.
  confidence   Float?
  /// Human-readable one-line summary of the reasoning ("considered
  /// patient's fatigue side-effect history and dose-response pattern
  /// before drafting the taper plan").
  summary      String?
  createdAt    DateTime @default(now())

  @@index([agentName, createdAt])
  @@index([agentJobId])
}

enum FeedbackAction {
  approved
  approved_with_edits
  rejected
  dismissed
}

model AgentFeedback {
  id             String         @id @default(cuid())
  organizationId String?
  agentName      String
  agentVersion   String?
  /// Optional links to the artifact the feedback is about.
  agentJobId     String?
  messageId      String?
  noteId         String?
  action         FeedbackAction
  reviewerId     String // user id
  /// If the reviewer edited the draft, the delta between original and
  /// final (plain text diff, not structured). Null for approved/rejected
  /// without edits.
  editDelta      String?
  /// Optional free-text note from the reviewer about why they edited /
  /// rejected. Structured tuning signal over time.
  reviewerNote   String?
  createdAt      DateTime       @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([agentName, action, createdAt])
  @@index([reviewerId, createdAt])
}

// --------------------------------------------------------------
// Cannabis Prescribing / Dosing
// --------------------------------------------------------------

enum ProductType {
  oil
  tincture
  capsule
  flower
  vape_cartridge
  edible
  topical
  suppository
  spray
  other
}

enum DeliveryRoute {
  oral
  sublingual
  inhalation
  topical
  rectal
  vaginal
}

model CannabisProduct {
  id                   String        @id @default(cuid())
  organizationId       String
  name                 String // e.g. "THC Infused Oil 10mg/mL"
  brand                String? // e.g. "Green Path Organics"
  productType          ProductType
  route                DeliveryRoute
  // Cannabinoid concentrations (mg per mL, mg per unit, or % for flower)
  thcConcentration     Float? // mg/mL for liquids, mg/unit for capsules, % for flower
  cbdConcentration     Float?
  cbnConcentration     Float?
  cbgConcentration     Float?
  thcCbdRatio          String? // e.g. "1:1", "20:1", "1:20"
  // Terpene profile (optional, structured)
  terpeneProfile       Json? // { myrcene: 0.5, limonene: 0.3, ... } in %
  // Units
  concentrationUnit    String        @default("mg/mL") // "mg/mL", "mg/unit", "%", "mg/g"
  unitSize             Float? // mL per bottle, units per pack, grams per container
  // Link to the marketplace listing. Null when no storefront product exists yet;
  // authoritative when set (supersedes the name-match bridge in ranking.ts).
  marketplaceProductId String?
  // Metadata
  description          String?
  active               Boolean       @default(true)
  createdAt            DateTime      @default(now())

  organization       Organization    @relation(fields: [organizationId], references: [id])
  regimens           DosingRegimen[]
  marketplaceProduct Product?        @relation("CannabisProductMarketplace", fields: [marketplaceProductId], references: [id], onDelete: SetNull)

  @@index([organizationId, active])
  @@index([marketplaceProductId])
}

model DosingRegimen {
  id                       String    @id @default(cuid())
  patientId                String
  productId                String
  prescribedById           String? // provider user id
  // Dosing
  volumePerDose            Float // mL, puffs, units, mg
  volumeUnit               String    @default("mL") // "mL", "puffs", "units", "mg", "drops"
  frequencyPerDay          Int       @default(1)
  timingInstructions       String? // e.g. "1 hour before bed", "after meals"
  // Auto-calculated mg (from product concentration * volume)
  calculatedThcMgPerDose   Float?
  calculatedCbdMgPerDose   Float?
  calculatedThcMgPerDay    Float?
  calculatedCbdMgPerDay    Float?
  // Duration
  startDate                DateTime  @default(now())
  endDate                  DateTime?
  active                   Boolean   @default(true)
  // Patient-facing instructions
  patientInstructions      String? // "Take 0.25 mL under the tongue twice daily"
  // Clinician notes
  clinicianNotes           String?
  // EMR-088: contraindication override — populated when prescribing despite
  // a flagged contraindication. Contains: { contraindicationIds, reason,
  // overriddenByUserId, overriddenAt }
  contraindicationOverride Json?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  patient  Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  product  CannabisProduct @relation(fields: [productId], references: [id])
  doseLogs DoseLog[]

  @@index([patientId, active])
}

model DoseLog {
  id             String         @id @default(cuid())
  patientId      String
  regimenId      String?
  // What was taken
  actualVolume   Float // what they actually took
  volumeUnit     String         @default("mL")
  estimatedThcMg Float? // auto-calculated from regimen product
  estimatedCbdMg Float?
  route          DeliveryRoute?
  // Context
  note           String?
  loggedAt       DateTime       @default(now())

  patient Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  regimen DosingRegimen? @relation(fields: [regimenId], references: [id])

  @@index([patientId, loggedAt])
}

// --------------------------------------------------------------
// Conventional Medications & Supplements
// --------------------------------------------------------------

enum MedicationType {
  prescription
  otc
  supplement
  cannabis
}

model PatientMedication {
  id          String         @id @default(cuid())
  patientId   String
  name        String // "Warfarin", "Melatonin", "Vitamin D"
  genericName String? // "warfarin sodium"
  type        MedicationType
  dosage      String? // "5mg daily"
  prescriber  String? // who prescribed it (external)
  active      Boolean        @default(true)
  startDate   DateTime?
  notes       String?
  createdAt   DateTime       @default(now())

  patient        Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  refillRequests RefillRequest[]

  @@index([patientId, active])
}

// --------------------------------------------------------------
// Research (stubbed for V1)
// --------------------------------------------------------------

model ResearchQuery {
  id        String   @id @default(cuid())
  userId    String?
  patientId String?
  queryText String
  createdAt DateTime @default(now())

  results ResearchResult[]

  @@index([userId, createdAt])
}

model ResearchResult {
  id                   String  @id @default(cuid())
  queryId              String
  title                String
  source               String
  year                 Int?
  summary              String
  citation             String
  url                  String? // link to PubMed, DOI, or full text
  pmid                 String? // PubMed ID if available
  quantitativeFindings Json?
  rank                 Int     @default(0)

  query ResearchQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------------
// Practice launch readiness
// --------------------------------------------------------------

model PracticeLaunchStatus {
  id             String    @id @default(cuid())
  organizationId String    @unique
  readinessScore Int       @default(0)
  blockers       Json      @default("[]")
  nextSteps      Json      @default("[]")
  goLiveAt       DateTime?
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------------
// Leafjourney Marketplace
// --------------------------------------------------------------

enum ProductStatus {
  draft
  active
  archived
  out_of_stock
}

enum VendorType {
  hemp_brand
  licensed_dispensary
}

enum VendorStatus {
  pending
  active
  suspended
  offboarded
}

// EMR-249: vendor portal auth realm. Roles map to UI surfaces:
// owner sees finance + 2FA-required ops; catalog_manager edits products;
// fulfillment ships orders; finance views payouts + 2FA-required.
enum VendorPortalRole {
  owner
  catalog_manager
  fulfillment
  finance
}

enum VendorUserStatus {
  invited
  active
  suspended
}

enum VendorDocumentType {
  insurance
  w9
  coa
}

enum VendorDocumentStatus {
  missing
  submitted
  approved
  rejected
}

model Product {
  id               String        @id @default(cuid())
  organizationId   String
  name             String
  slug             String        @unique
  brand            String
  description      String
  shortDescription String?
  price            Float
  compareAtPrice   Float?
  status           ProductStatus @default(draft)
  format           String // tincture, flower, edible, topical, capsule, vape
  imageUrl         String?
  images           String[]      @default([])

  // Cannabinoid profile
  thcContent     Float?
  cbdContent     Float?
  cbnContent     Float?
  thcvContent    Float?
  terpeneProfile Json?
  strainType     String? // indica, sativa, hybrid, n/a

  // Use-case metadata
  symptoms  String[] @default([])
  goals     String[] @default([])
  useCases  String[] @default([])
  onsetTime String?
  duration  String?

  // Dosage
  dosageGuidance   String?
  beginnerFriendly Boolean @default(false)

  // Storefront UI — pre-formatted display values for the Leafmart shelf.
  // When null, the UI mapper falls back to category/format-derived defaults.
  bgColor      String? // CSS color or var() for the pastel shelf background
  deepColor    String? // CSS color for the silhouette stroke
  displayShape String? // "bottle" | "can" | "jar" | "tin" | "serum" | "box"
  doseLabel    String? // Pre-formatted dose, e.g. "30ml · 1500mg"

  // Outcome metrics — % of patients who reported help, plus sample size.
  // Powers the outcome chip on product cards.
  outcomePct        Float?
  outcomeSampleSize Int?

  // Trust
  labVerified    Boolean @default(false)
  coaUrl         String?
  // EMR-242: link to the VendorDocument(documentType='coa') that
  // covers this product. The cron auto-delists on expiry.
  coaDocumentId  String?
  clinicianPick  Boolean @default(false)
  clinicianNote  String?
  requires21Plus Boolean @default(false)

  // Inventory
  inStock        Boolean @default(true)
  inventoryCount Int     @default(0)

  // Ratings
  averageRating Float @default(0)
  reviewCount   Int   @default(0)

  // Ordering + features
  sortOrder Int     @default(0)
  featured  Boolean @default(false)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  variants         ProductVariant[]
  reviews          ProductReview[]
  orderItems       OrderItem[]
  cartItems        CartItem[]
  categoryMappings ProductCategory[]
  cannabisProducts CannabisProduct[] @relation("CannabisProductMarketplace")

  @@index([organizationId, status])
  @@index([clinicianPick])
  @@index([featured])
  @@index([coaDocumentId])
}

model Vendor {
  id                       String       @id @default(cuid())
  organizationId           String
  slug                     String       @unique
  name                     String
  vendorType               VendorType
  categories               String[]     @default([])
  productLines             String[]     @default([])
  takeRatePct              Float        @default(0.10)
  foundingPartnerFlag      Boolean      @default(false)
  foundingPartnerExpiresAt DateTime?
  payoutSchedule           String       @default("weekly")
  reservePct               Float?       @default(0.10)
  reserveDays              Int?         @default(14)
  // EMR-244: USPS state codes the vendor is licensed/permitted to ship
  // to. Empty array = not configured → all shipments blocked (fail-safe).
  shippableStates          String[]     @default([])
  status                   VendorStatus @default(pending)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents    VendorDocument[]
  users        VendorUser[]

  @@index([organizationId, status])
}

// EMR-249: vendor portal user. Distinct table from EMR User so a
// vendor session can never authenticate to clinical routes (different
// cookie name AND different DB lookup table). passwordHash uses
// bcrypt; totpSecret is base32; null totpEnabledAt = 2FA not enrolled.
model VendorUser {
  id            String           @id @default(cuid())
  vendorId      String
  email         String
  passwordHash  String
  role          VendorPortalRole
  status        VendorUserStatus @default(invited)
  totpSecret    String?
  totpEnabledAt DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  vendor   Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  sessions VendorSession[]

  @@unique([vendorId, email])
  @@index([email])
}

// EMR-249: opaque-token session store for vendor portal. The cookie
// holds the plaintext token; DB stores its SHA-256 so a DB leak
// alone can't impersonate a session.
model VendorSession {
  id               String   @id @default(cuid())
  vendorUserId     String
  sessionTokenHash String   @unique
  expiresAt        DateTime
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime @default(now())

  user VendorUser @relation(fields: [vendorUserId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model VendorDocument {
  id             String               @id @default(cuid())
  organizationId String
  vendorId       String
  documentType   VendorDocumentType
  fileUrl        String?
  // EMR-242: COAs are public buyer-facing docs, served via publicUrl.
  // W-9s are admin-only and only accessible via the encrypted fileUrl.
  publicUrl      String?
  // EMR-242: COA expiration drives auto-delist + reminder cadence.
  expiresAt      DateTime?
  status         VendorDocumentStatus @default(missing)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor       Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, documentType])
  @@index([organizationId, status])
  @@index([documentType, expiresAt])
}

// EMR-238: Outcome Event Recorder. Durable log of patient/product
// interactions that the future ranking engine (EMR-230) reads. No
// Prisma back-relations on Organization/Patient/Product/Vendor —
// callers query by id explicitly so this surface is independent of
// the rest of the schema.
enum MarketplaceEventType {
  purchase
  regimen_start
  regimen_end
  pro_submission
  adverse_event
  refund
  return_initiated
}

model MarketplaceEvent {
  id             String               @id @default(cuid())
  organizationId String
  patientId      String?
  productId      String?
  lotId          String?
  vendorId       String?
  eventType      MarketplaceEventType
  outcomeScores  Json?
  metadata       Json?
  createdAt      DateTime             @default(now())

  @@index([organizationId, eventType, createdAt])
  @@index([productId, createdAt])
  @@index([patientId, createdAt])
  @@index([vendorId, createdAt])
}

model ProductVariant {
  id             String   @id @default(cuid())
  productId      String
  name           String
  upc            String? // Universal Product Code for product itemization
  price          Float
  compareAtPrice Float?
  inStock        Boolean  @default(true)
  inventoryCount Int      @default(0)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  cartItems  CartItem[]

  @@index([productId])
}

model MarketplaceCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  type        String   @default("standard") // standard, symptom, goal, format
  imageUrl    String?
  icon        String?
  sortOrder   Int      @default(0)
  parentId    String?
  createdAt   DateTime @default(now())

  parent   MarketplaceCategory?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children MarketplaceCategory[] @relation("CategoryChildren")
  products ProductCategory[]

  @@index([type])
  @@index([parentId])
}

model ProductCategory {
  id         String @id @default(cuid())
  productId  String
  categoryId String

  product  Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  category MarketplaceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  patientId  String?
  authorName String
  rating     Int
  title      String?
  body       String?
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())

  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  patient Patient? @relation(fields: [patientId], references: [id])

  @@index([productId, createdAt])
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

model Order {
  id              String      @id @default(cuid())
  organizationId  String
  patientId       String
  status          OrderStatus @default(pending)
  subtotal        Float
  tax             Float       @default(0)
  total           Float
  notes           String?
  shippingAddress Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id])
  items        OrderItem[]

  @@index([patientId, createdAt])
  @@index([organizationId, status])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  variantId  String?
  quantity   Int
  unitPrice  Float
  totalPrice Float
  createdAt  DateTime @default(now())

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

// One cart per patient. Items survive browser reload; checkout converts to Order.
model Cart {
  id        String   @id @default(cuid())
  patientId String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  items   CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, variantId])
  @@index([cartId])
}

// --------------------------------------------------------------
// Notifications
// --------------------------------------------------------------

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // appointment_reminder, message_received, lab_results, etc.
  priority  String    @default("normal") // urgent, normal, low
  title     String
  body      String
  href      String? // deep link to relevant page
  read      Boolean   @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

// --------------------------------------------------------------
// Referrals
// --------------------------------------------------------------

model Referral {
  id                     String    @id @default(cuid())
  organizationId         String
  patientId              String
  direction              String // outbound | inbound
  status                 String    @default("draft") // draft, sent, received, scheduled, completed, cancelled, declined
  priority               String    @default("routine") // stat, urgent, routine
  referringProviderName  String
  referringPracticeName  String
  referredToProviderName String
  referredToSpecialty    String
  referredToPracticeName String
  referredToPhone        String?
  referredToFax          String?
  reason                 String
  diagnosisCodes         Json      @default("[]")
  clinicalNotes          String?
  attachedDocumentIds    Json      @default("[]")
  sentAt                 DateTime?
  receivedAt             DateTime?
  scheduledDate          DateTime?
  completedAt            DateTime?
  completionNotes        String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, status])
  @@index([organizationId, status])
}

// --------------------------------------------------------------
// Consent Forms
// --------------------------------------------------------------

model SignedConsent {
  id            String   @id @default(cuid())
  patientId     String
  templateId    String
  templateName  String
  version       String
  responses     Json
  signatureData String?  @db.Text // base64 signature image
  signedAt      DateTime @default(now())
  ipAddress     String?
  userAgent     String?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, templateId])
}

// --------------------------------------------------------------
// State Compliance Forms
// --------------------------------------------------------------

model StateComplianceForm {
  id             String    @id @default(cuid())
  organizationId String
  patientId      String
  encounterId    String?
  stateCode      String
  formTemplateId String
  formName       String
  fields         Json
  status         String    @default("draft") // draft, complete, submitted
  signedBy       String?
  signedAt       DateTime?
  submittedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, stateCode])
  @@index([organizationId, status])
}

// --------------------------------------------------------------
// Caregiver Access
// --------------------------------------------------------------

model CaregiverInvite {
  id              String    @id @default(cuid())
  patientId       String
  caregiverEmail  String
  caregiverName   String
  relationship    String
  accessLevel     String    @default("read_only") // read_only, full, emergency_only
  status          String    @default("invited") // invited, active, revoked, expired
  caregiverUserId String? // set when accepted
  invitedAt       DateTime  @default(now())
  acceptedAt      DateTime?
  revokedAt       DateTime?
  expiresAt       DateTime?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, status])
  @@index([caregiverEmail])
}

// --------------------------------------------------------------
// Satisfaction Survey
// --------------------------------------------------------------

model SurveySubmission {
  id          String   @id @default(cuid())
  patientId   String
  encounterId String?
  surveyType  String   @default("post_visit")
  responses   Json // Array of { questionId, value }
  npsScore    Int?
  submittedAt DateTime @default(now())

  patient   Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter Encounter? @relation(fields: [encounterId], references: [id], onDelete: SetNull)

  @@index([patientId, submittedAt])
}

// --------------------------------------------------------------
// Custom Intake Templates
// --------------------------------------------------------------

model IntakeFormTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  sections       Json // Array of { id, title, description }
  fields         Json // Array of IntakeField objects
  version        Int      @default(1)
  isDefault      Boolean  @default(false)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, active])
}

// --------------------------------------------------------------
// Communication Preferences
// --------------------------------------------------------------

model CommunicationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  smsOptIn        Boolean  @default(false)
  emailFrequency  String   @default("instant") // instant, daily, weekly, off
  quietHoursStart String? // "22:00"
  quietHoursEnd   String? // "07:00"
  preferences     Json     @default("{}") // per-category: { appointments: { email: true, sms: false }, ... }
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------------
// Lab Review — MALLIK-006 (Phase 1 Mission Control)
// --------------------------------------------------------------
// Structured lab result for the physician review queue. Distinct
// from the Document-based lab flow (which is file metadata only).
// LabResult carries marker-level values and is the source of truth
// for the current vs. prior comparison overlay.
// --------------------------------------------------------------

model LabResult {
  id             String    @id @default(cuid())
  organizationId String
  patientId      String
  panelName      String // e.g. "CMP", "Lipid panel", "HbA1c", "Liver panel"
  receivedAt     DateTime
  // Structured results. Shape: { markerName: { value: number, unit: string, refLow?: number, refHigh?: number, abnormal: boolean } }
  results        Json
  // Denormalized signal for queue filtering. Computed on insert: true if any marker is outside its refRange.
  abnormalFlag   Boolean   @default(false)
  // Sign-off tracking (null until clinician signs)
  signedById     String?
  signedAt       DateTime?
  reviewOutcome  String? // "looks_good" | "needs_followup" | "repeat" | "routed_to_ma"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  patient       Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  organization  Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  signedBy      User?           @relation("LabResultSigner", fields: [signedById], references: [id])
  outreach      LabOutreach?
  monitoringFor RefillRequest[] @relation("RefillMonitoringLab")

  @@index([organizationId, signedAt])
  @@index([patientId, receivedAt])
}

model LabOutreach {
  id            String    @id @default(cuid())
  labResultId   String    @unique
  patientDraft  String // AI-drafted patient-friendly message
  maDraft       String // AI-drafted MA task one-liner
  physicianNote String // AI-drafted chart one-liner
  // Channel selection: { patientMessage: bool, sms: bool, voice: bool, pdf: bool, fax: bool, maTask: bool }
  routing       Json
  status        String    @default("draft") // "draft" | "approved" | "sent"
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  labResult  LabResult @relation(fields: [labResultId], references: [id], onDelete: Cascade)
  approvedBy User?     @relation("LabOutreachApprover", fields: [approvedById], references: [id])
}

// --------------------------------------------------------------
// Refill Queue — MALLIK-007 (Phase 1 Mission Control)
// --------------------------------------------------------------
// Physician-facing refill request queue. Each row surfaces the
// minimum context a physician needs to approve without opening
// the patient chart: med + dose + qty + pharmacy + last relevant
// lab. The Refill Copilot (src/lib/agents/refill-copilot-agent.ts)
// precomputes a suggested action plus any safety flags.
//
// Pharmacy is inlined as scalar fields at Phase 1. When the
// Surescripts integration lands (MALLIK-012) we normalize into a
// Pharmacy model and point this FK at it.
// --------------------------------------------------------------

model RefillRequest {
  id                String    @id @default(cuid())
  organizationId    String
  patientId         String
  medicationId      String
  requestedQty      Int
  requestedDays     Int?
  // Pharmacy (denormalized for Phase 1)
  pharmacyName      String
  pharmacyPhone     String?
  pharmacyAddress   String?
  // Copilot context
  lastRelevantLabId String? // optional link to the lab the copilot thinks matters
  // Copilot outputs
  copilotSuggestion String? // "approve" | "deny" | "review"
  safetyFlags       Json      @default("[]") // string[] of flag codes
  rationale         String? // one-liner from the copilot
  // Lifecycle
  receivedAt        DateTime  @default(now())
  status            String    @default("new") // "new" | "flagged" | "approved" | "sent" | "denied"
  signedById        String?
  signedAt          DateTime?
  deniedReason      String?
  faxPdfUrl         String? // populated by Phase 1 fax-PDF stub on sign
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  medication      PatientMedication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  signedBy        User?             @relation("RefillSigner", fields: [signedById], references: [id])
  lastRelevantLab LabResult?        @relation("RefillMonitoringLab", fields: [lastRelevantLabId], references: [id])

  @@index([organizationId, status])
  @@index([patientId, receivedAt])
}

// --------------------------------------------------------------
// CFO / Controller — Books, Reports, Cash, Expenses, Equity
// --------------------------------------------------------------
// The CFO agent reads everything below to produce real-time P&L,
// cash flow statements, and balance sheets. Every dollar in or
// out of the practice flows through one of these tables.
// --------------------------------------------------------------

enum ExpenseCategory {
  cogs_inventory // cost of goods (cannabis products, medical supplies)
  cogs_lab // lab fees, COA testing
  payroll_clinical // physicians, NPs, PAs, MAs
  payroll_admin // billing staff, ops staff, executives
  payroll_taxes // employer FICA / SUTA / FUTA
  benefits // health insurance, retirement match
  rent // clinic rent
  utilities // power, water, internet
  software // SaaS subscriptions
  insurance // malpractice, business, cyber
  marketing // ads, content, conferences
  legal_professional // attorneys, CPAs, consultants
  office_supplies
  equipment // small equipment, < capitalize threshold
  travel
  meals_entertainment
  banking_fees // merchant fees, wire fees, interest
  taxes_state_local // state excise, local cannabis tax (non-payroll)
  taxes_federal // estimated federal income tax
  depreciation // non-cash, allocated from FixedAsset
  amortization
  bad_debt // write-offs of patient AR
  refunds_chargebacks
  contractor // 1099 contractors
  research_development
  training_education
  charitable
  other
}

enum ExpenseStatus {
  draft
  pending_approval
  approved
  paid
  void
}

/// A single expense the practice incurs. Cash impact is captured when
/// `paidAt` is non-null. Recurring expenses spawn child rows on cadence.
model Expense {
  id              String          @id @default(cuid())
  organizationId  String
  category        ExpenseCategory
  vendor          String
  description     String
  amountCents     Int // always positive — sign is implied by category
  taxCents        Int             @default(0)
  totalCents      Int // amount + tax
  occurredOn      DateTime // when the cost was incurred (accrual date)
  paidAt          DateTime? // when cash actually left (cash basis date)
  paymentMethod   String? // ach | card | check | wire | cash
  bankAccountId   String? // which account paid for it
  receiptUrl      String?
  invoiceNumber   String?
  status          ExpenseStatus   @default(approved)
  recurringRuleId String? // links to a parent RecurringExpense
  notes           String?
  metadata        Json? // free-form: GL code, dept, project, memo
  createdByUserId String?
  createdByAgent  String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount   BankAccount?      @relation(fields: [bankAccountId], references: [id])
  recurringRule RecurringExpense? @relation(fields: [recurringRuleId], references: [id])

  @@index([organizationId, occurredOn])
  @@index([organizationId, category, occurredOn])
  @@index([organizationId, paidAt])
}

/// Recurring expense templates (e.g. monthly rent, weekly payroll).
/// A nightly job materializes the next Expense row when due.
model RecurringExpense {
  id             String          @id @default(cuid())
  organizationId String
  category       ExpenseCategory
  vendor         String
  description    String
  amountCents    Int
  cadence        String // weekly | biweekly | semimonthly | monthly | quarterly | annual
  dayOfPeriod    Int? // day-of-month or day-of-week anchor
  bankAccountId  String?
  active         Boolean         @default(true)
  startsOn       DateTime
  endsOn         DateTime?
  lastSpawnedAt  DateTime?
  nextSpawnAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount? @relation(fields: [bankAccountId], references: [id])
  expenses     Expense[]

  @@index([organizationId, active, nextSpawnAt])
}

enum BankAccountType {
  checking
  savings
  merchant
  credit_card
  line_of_credit
  payroll
  reserves
}

/// A real-world bank or merchant account. Balances roll up into the
/// balance sheet's cash + cash-equivalents line.
model BankAccount {
  id                  String          @id @default(cuid())
  organizationId      String
  name                String
  type                BankAccountType
  institution         String?
  last4               String?
  openingBalanceCents Int             @default(0)
  currentBalanceCents Int             @default(0) // synced or manually updated
  asOfDate            DateTime        @default(now())
  isActive            Boolean         @default(true)
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expenses          Expense[]
  recurringExpenses RecurringExpense[]
  cashFlowEntries   CashFlowEntry[]
  bankDeposits      BankDeposit[]

  @@index([organizationId, isActive])
}

enum CashFlowDirection {
  in
  out
}

enum CashFlowActivity {
  operating // collections, payroll, rent, marketing
  investing // equipment purchase, asset sale
  financing // loan draw, loan repayment, owner equity, dividends
}

/// Every actual cash movement. Distinct from FinancialEvent (which is
/// accrual / claim-lifecycle). The CFO agent consumes this for the cash
/// flow statement.
model CashFlowEntry {
  id             String            @id @default(cuid())
  organizationId String
  bankAccountId  String?
  direction      CashFlowDirection
  activity       CashFlowActivity
  amountCents    Int // always positive — direction tells sign
  description    String
  occurredOn     DateTime
  // Source linkage (any of these may be set)
  expenseId      String?
  paymentId      String?
  orderId        String?
  liabilityId    String?
  fixedAssetId   String?
  equityEntryId  String?
  metadata       Json?
  createdByAgent String?
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount? @relation(fields: [bankAccountId], references: [id])

  @@index([organizationId, occurredOn])
  @@index([organizationId, activity, occurredOn])
}

enum FixedAssetCategory {
  medical_equipment
  computer_hardware
  furniture
  leasehold_improvement
  vehicle
  software_capitalized
  deposit
  other
}

/// Capitalized assets — appear on the balance sheet, depreciated over
/// useful life into the P&L as `depreciation` expense.
model FixedAsset {
  id                     String             @id @default(cuid())
  organizationId         String
  name                   String
  category               FixedAssetCategory
  purchaseDate           DateTime
  acquiredCostCents      Int
  salvageValueCents      Int                @default(0)
  usefulLifeMonths       Int
  accumulatedDeprecCents Int                @default(0)
  disposedAt             DateTime?
  disposalProceedsCents  Int?
  notes                  String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, disposedAt])
}

enum LiabilityType {
  loan_term // SBA, bank term loan
  line_of_credit
  credit_card
  accounts_payable // vendor AP not yet paid
  payroll_payable
  tax_payable
  deferred_revenue // patient prepay, gift cards
  capital_lease
  other
}

/// Anything the practice owes. Balance shrinks as cash flows out.
model Liability {
  id                  String        @id @default(cuid())
  organizationId      String
  name                String
  type                LiabilityType
  principalCents      Int // original principal
  balanceCents        Int // current outstanding
  interestRate        Float? // annual %, e.g. 0.085
  termMonths          Int?
  monthlyPaymentCents Int?
  startDate           DateTime
  maturityDate        DateTime?
  closedAt            DateTime?
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, closedAt])
  @@index([organizationId, type])
}

enum EquityEntryType {
  capital_contribution // owner puts cash in
  distribution // owner takes cash out
  retained_earnings_adjustment
  stock_issuance
  stock_buyback
  prior_period_adjustment
}

/// Owners' equity movements. The balance sheet's equity line is opening
/// equity + retained earnings + sum(capital contributions - distributions).
model EquityEntry {
  id             String          @id @default(cuid())
  organizationId String
  type           EquityEntryType
  amountCents    Int // signed: + into the company, - out of the company
  occurredOn     DateTime
  ownerName      String?
  description    String
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, occurredOn])
}

enum FinancialReportType {
  pnl
  cash_flow
  balance_sheet
  kpi_dashboard
  cfo_briefing // narrative-only, ties the three statements together
}

enum FinancialReportPeriod {
  daily
  weekly
  monthly
  quarterly
  annual
  custom
}

/// Snapshot of a generated financial report. The CFO agent writes one
/// row per generation; the operator UI renders the latest per type.
/// The full statement lives in `data` as a versioned JSON shape.
model FinancialReport {
  id                    String                @id @default(cuid())
  organizationId        String
  type                  FinancialReportType
  period                FinancialReportPeriod
  periodStart           DateTime
  periodEnd             DateTime
  generatedAt           DateTime              @default(now())
  generatedBy           String // "agent:cfo@1.0.0" or user id
  // Headline metrics for fast querying without parsing JSON
  revenueCents          Int                   @default(0)
  cogsCents             Int                   @default(0)
  grossProfitCents      Int                   @default(0)
  opexCents             Int                   @default(0)
  ebitdaCents           Int                   @default(0)
  netIncomeCents        Int                   @default(0)
  cashCents             Int                   @default(0)
  arCents               Int                   @default(0)
  apCents               Int                   @default(0)
  totalAssetsCents      Int                   @default(0)
  totalLiabilitiesCents Int                   @default(0)
  totalEquityCents      Int                   @default(0)
  // Full structured statement
  data                  Json
  // CFO narrative + flagged anomalies
  narrative             String?
  anomalies             Json                  @default("[]")
  metadata              Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type, periodEnd])
  @@index([organizationId, generatedAt])
}

enum FinancialGoalKind {
  revenue_target
  gross_margin_target
  ebitda_target
  cash_runway_min
  ar_days_max
  collection_rate_min
  custom
}

/// Operator-defined targets the CFO agent benchmarks against and flags.
model FinancialGoal {
  id             String                @id @default(cuid())
  organizationId String
  kind           FinancialGoalKind
  label          String
  targetCents    Int? // for $-denominated goals
  targetPct      Float? // for ratio / % goals
  targetDays     Int? // for days-based goals (runway, AR)
  period         FinancialReportPeriod @default(monthly)
  active         Boolean               @default(true)
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, active])
}

// ─────────────────────────────────────────────────────────────────────────
// Education — Cannabis Combo Wheel compounds
// Global educational catalog (cannabinoids + terpenes) powering the
// interactive Combo Wheel on the public Education tab. Not patient/PHI data.
// ─────────────────────────────────────────────────────────────────────────

enum CompoundType {
  cannabinoid
  terpene
}

enum CompoundEvidenceLevel {
  strong
  moderate
  emerging
}

/// Single compound entry on the Cannabis Combo Wheel. The wheel is purely
/// educational — there is no organization scope, no PHI, and rows are
/// publicly readable. Content authored/edited by the curation team.
model EducationCompound {
  id          String                @id // stable slug, e.g. "thc", "myrcene"
  name        String // display name, e.g. "THC", "Myrcene"
  type        CompoundType
  color       String // hex color for the wheel segment, e.g. "#3A8560"
  evidence    CompoundEvidenceLevel
  description String // 1–2 sentence pharmacology summary
  symptoms    String[] // conditions this compound may target
  benefits    String[] // therapeutic benefits
  risks       String[] // cautions / side effects
  // Wheel display ordering. Lower values render first within their ring.
  // Uniqueness is enforced per (type, sortOrder) so cannabinoid and terpene
  // rings each have their own sequence starting at 0.
  sortOrder   Int                   @default(0)
  // Soft-disable without deleting the row (preserves history / FKs).
  active      Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([type, sortOrder])
  @@index([type, active, sortOrder])
}

// --------------------------------------------------------------
// Track 7 — Financial Operations & Lockbox
// EMR-221  ERA / 835 ingestion pipeline
// EMR-223  Per-payer contract allowables
// EMR-224  Lockbox / bank deposit matching
// EMR-225  Patient statement generator (uses existing Statement model)
// EMR-227  NSF / chargeback handler
// EMR-228  Appeal tracker + outcome learning
// EMR-229  Prior-auth workflow
// EMR-230  RCM daily-close report
// --------------------------------------------------------------

enum EraFileStatus {
  received  // payload stored, not yet parsed
  parsed    // 835 parsed into AdjudicationResult rows
  posted    // financial events written, claim balances updated
  failed    // parse error — see parseError
  duplicate // already ingested under a different bankReference (deduped)
}

/// Raw ERA / 835 payload from the clearinghouse. One row per check / EFT
/// trace from the payer; one ERA can carry payment for many claims.
model EraFile {
  id               String        @id @default(cuid())
  organizationId   String
  payerName        String
  payerId          String?
  /// EFT trace number, paper check number, or "EFT-<date>" for synthetic.
  /// Combined with payerId is the dedupe key — a retried delivery from
  /// the clearinghouse never double-posts.
  checkNumber      String
  checkDate        DateTime
  paymentMethod    String        @default("ach") // ach | check | vcc | fedwire
  totalAmountCents Int
  /// Full payload — raw EDI 835 text or the gateway's pre-parsed JSON
  /// envelope. Stored verbatim for audit and re-parsing.
  rawPayload       String
  /// sha256 of the normalized payload. Second-line dedupe defence so
  /// payloads that arrive without a stable check# still dedupe.
  contentHash      String
  status           EraFileStatus @default(received)
  parseError       String?
  parsedAt         DateTime?
  postedAt         DateTime?
  receivedAt       DateTime      @default(now())

  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  adjudications      AdjudicationResult[]
  bankDepositMatches BankDepositMatch[]

  @@unique([organizationId, payerId, checkNumber])
  @@unique([organizationId, contentHash])
  @@index([organizationId, receivedAt])
  @@index([status])
}

/// A negotiated payer contract — owns the per-CPT allowables the
/// underpayment detector compares against. Effective-date ranged so a
/// new contract for the same payer supersedes the old one cleanly.
model PayerContract {
  id             String    @id @default(cuid())
  organizationId String
  payerId        String
  payerName      String
  contractName   String
  effectiveStart DateTime
  effectiveEnd   DateTime?
  notes          String?
  active         Boolean   @default(true)
  /// Source filename / hash of the imported contract document, for audit.
  sourceRef      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rates        PayerContractRate[]

  @@unique([organizationId, payerId, effectiveStart])
  @@index([organizationId, payerId, active])
}

/// One row per (CPT × modifier) on a contract. Modifier null = base rate.
/// Composite uniqueness lets a contract carry both base + modified rates
/// for the same CPT (e.g. 99214 base $130, 99214-95 telehealth $115).
model PayerContractRate {
  id           String  @id @default(cuid())
  contractId   String
  cptCode      String
  modifier     String?
  allowedCents Int
  notes        String?

  contract PayerContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, cptCode, modifier])
  @@index([cptCode])
}

enum BankDepositStatus {
  pending           // not yet attempted to match
  matched           // matched to ERA(s) / payment(s) — sum equals deposit
  partially_matched // matched some but not all
  unmatched         // tried, found no candidates
  variance          // matched but sums don't reconcile within tolerance
}

/// A real-world deposit on the practice's bank statement. Lockbox
/// reconciliation matches each deposit to one or more ERAs / patient
/// payments. Drives EMR-224 + EMR-230 daily close.
model BankDeposit {
  id                 String            @id @default(cuid())
  organizationId     String
  bankAccountId      String?
  depositDate        DateTime
  amountCents        Int
  /// Bank-side trace identifier (deposit slip id, IAT trace, lockbox
  /// reference). Globally unique within the org to dedupe on re-import.
  bankReference      String
  source             String            @default("lockbox") // lockbox | ach | wire | branch | other
  /// Original line as it appeared in the bank statement (CSV row,
  /// BAI2 record, or OFX <STMTTRN>).
  rawLine            String?
  status             BankDepositStatus @default(pending)
  matchedAmountCents Int               @default(0)
  /// matched_total - amount; non-zero when partially_matched / variance.
  varianceCents      Int?
  notes              String?
  createdAt          DateTime          @default(now())
  reconciledAt       DateTime?

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount?       @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  matches      BankDepositMatch[]

  @@unique([organizationId, bankReference])
  @@index([organizationId, depositDate])
  @@index([status])
}

/// Edge between a BankDeposit and the underlying ERA(s) / Payment(s)
/// that make up the deposit total. A many-to-many join with amount,
/// because one deposit can split across several ERAs and one ERA can
/// (rarely) hit two deposits.
model BankDepositMatch {
  id          String   @id @default(cuid())
  depositId   String
  eraFileId   String?
  paymentId   String?
  amountCents Int
  matchedAt   DateTime @default(now())
  /// "auto" for the matcher; otherwise the user id that confirmed the
  /// match manually.
  matchedBy   String

  deposit BankDeposit @relation(fields: [depositId], references: [id], onDelete: Cascade)
  eraFile EraFile?    @relation(fields: [eraFileId], references: [id], onDelete: SetNull)
  payment Payment?    @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([depositId])
  @@index([eraFileId])
  @@index([paymentId])
}

enum AppealResult {
  pending
  overturned   // payer reversed the denial — money recovered
  upheld       // payer kept the denial — no recovery
  partial      // partial recovery
  withdrawn    // we pulled the appeal
  no_response  // payer never replied within the SLA
}

/// Outcome of an appeal — feeds the learning loop. Each overturned
/// outcome writes a `BillingMemory` row for the (payer, CARC, argument)
/// combination so future appeals lead with the winning argument.
model AppealOutcome {
  id             String       @id @default(cuid())
  organizationId String
  appealPacketId String       @unique
  claimId        String
  payerId        String?
  payerName      String
  /// CARC the appeal was responding to — primary signal for the
  /// learning loop.
  carcCode       String?
  rarcCode       String?
  /// Tags identifying the argument(s) used in the appeal letter.
  /// e.g. ["medical_necessity", "modifier_correction", "policy_citation"].
  /// Used by the learning loop to score which argument types win for
  /// which (payer, CARC) combination.
  argumentTags   String[]     @default([])
  decisionDate   DateTime?
  recoveredCents Int          @default(0)
  result         AppealResult @default(pending)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appealPacket AppealPacket @relation(fields: [appealPacketId], references: [id], onDelete: Cascade)
  claim        Claim        @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([organizationId, payerName, result])
  @@index([carcCode, result])
}

enum PriorAuthStatus {
  draft       // assembled, not yet submitted
  submitted   // sent to payer / portal
  approved    // payer approved — has approvalNumber + expiresAt
  denied      // payer denied
  expired     // approval lapsed before service rendered
  withdrawn   // we pulled the request
}

/// Prior authorization workflow. Cannabis services trigger PA on most
/// commercial payers; the claim-construction agent gates submission on
/// a valid PA where required (per `payer-rules.requiresPriorAuthForCannabis`).
model PriorAuthorization {
  id             String          @id @default(cuid())
  organizationId String
  patientId      String
  payerName      String
  payerId        String?
  /// CPT codes covered by the request. The whole request is a single PA
  /// even when it covers multiple codes, since payers issue one
  /// approvalNumber per request.
  cptCodes       String[]        @default([])
  icd10Codes     String[]        @default([])
  unitsRequested Int             @default(1)
  status         PriorAuthStatus @default(draft)
  submittedAt    DateTime?
  approvalNumber String?
  approvedUnits  Int?
  expiresAt      DateTime?
  /// The full assembled packet — DSM-5 severity, treatment plan, prior
  /// failures. Kept on the row so the same packet can be replayed for
  /// appeals (EMR-228 reads it for medical-necessity arguments).
  packetPayload  Json?
  /// Adapter that submitted the packet ("availity-pa", "carecentrix",
  /// "manual_fax", etc.). Null when still in draft.
  portalAdapter  String?
  /// Payer-side reference id (their case number or PA id). Distinct
  /// from approvalNumber, which only exists when status=approved.
  externalRef    String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([patientId, status])
  @@index([expiresAt])
}

/// Per-day rollup of every metric the practice owner needs in one view.
/// Generated by the daily-close job at 23:59 local; mailed out the next
/// morning. The dashboard query reads the latest row + computes deltas.
model RcmDailyClose {
  id                 String   @id @default(cuid())
  organizationId     String
  closeDate          DateTime @db.Date
  // -- Counts --------------------------------------------------------
  claimsCreated      Int      @default(0)
  claimsSubmitted    Int      @default(0)
  claimsAccepted     Int      @default(0)
  claimsRejected     Int      @default(0)
  claimsPaid         Int      @default(0)
  claimsDenied       Int      @default(0)
  claimsAppealed     Int      @default(0)
  claimsWrittenOff   Int      @default(0)
  // -- Dollars (cents) ----------------------------------------------
  billedCents        Int      @default(0)
  allowedCents       Int      @default(0)
  paidCents          Int      @default(0)
  adjustmentCents    Int      @default(0)
  patientRespCents   Int      @default(0)
  outstandingArCents Int      @default(0)
  arBucket0to30      Int      @default(0)
  arBucket31to60     Int      @default(0)
  arBucket61to90     Int      @default(0)
  arBucket91to120    Int      @default(0)
  arBucket120plus    Int      @default(0)
  // -- Exception counters (full lists computed live) ----------------
  staleClaims        Int      @default(0)
  unbalancedBatches  Int      @default(0)
  pendingTakebacks   Int      @default(0)
  unmatchedDeposits  Int      @default(0)
  overdueAppeals     Int      @default(0)
  // -- Delivery -----------------------------------------------------
  emailedAt  DateTime?
  exportedAt DateTime?
  createdAt  DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, closeDate])
  @@index([closeDate])
}

enum NsfEventType {
  nsf         // patient card / ACH bounced
  chargeback  // disputed and clawed back by issuer
  reversal    // clearinghouse-initiated reversal (rare)
}

/// Negative-payment event: a card NSF, an issuer chargeback, or a
/// clearinghouse reversal. Reverses the original FinancialEvent and
/// re-opens the claim balance for collections, with NSF-specific tone.
model NsfEvent {
  id             String       @id @default(cuid())
  organizationId String
  paymentId      String
  claimId        String?
  type           NsfEventType
  occurredAt     DateTime
  /// Always positive — the magnitude of the reversed amount. The
  /// matching FinancialEvent will be written as a negative entry.
  amountCents    Int
  bankFeeCents   Int          @default(0)
  /// Bank-provided reason ("R01 NSF", "fraud", "cancelled by consumer").
  reason         String?
  resolved       Boolean      @default(false)
  resolvedAt     DateTime?
  notes          String?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payment      Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  claim        Claim?       @relation(fields: [claimId], references: [id], onDelete: SetNull)

  @@index([organizationId, occurredAt])
  @@index([paymentId])
}

// ─────────────────────────────────────────────────────────────────────────
// Track 3 — EDI & Claim Generation
// EMR-216 generator + EMR-217 gateway adapter + EMR-218 payer rules DB
// + EMR-219 secondary claims + EMR-220 NPI/TaxID + EMR-222 NCCI/MUE
// ─────────────────────────────────────────────────────────────────────────

enum PayerClass {
  commercial
  government
  medicare_advantage
  medicaid_managed
  workers_comp
  self_pay
  other
}

enum CorrectedClaimFrequency {
  c7        // standard replacement
  c6        // adjustment
  c8_then_1 // void + rebill
}

/// EMR-218 — DB-backed payer rules. Mirrors the in-code shape from
/// src/lib/billing/payer-rules.ts. resolvePayerRuleAsync() prefers DB
/// rows when present, falls through to the in-code PAYER_RULES array.
model PayerRule {
  id                           String                  @id // EDI payer id or slug
  organizationId               String? // null = global default; non-null = org-specific override
  displayName                  String
  aliases                      String[]                @default([])
  class                        PayerClass
  timelyFilingDays             Int
  correctedTimelyFilingDays    Int
  appealLevel1Days             Int
  appealLevel2Days             Int
  appealExternalReviewDays     Int? // null when payer has no external review path
  ackSlaDays                   Int
  adjudicationSlaDays          Int
  eligibilityTtlHours          Int
  correctedClaimFrequency      CorrectedClaimFrequency
  honorsMod25OnZ71             Boolean
  requiresPriorAuthForCannabis Boolean
  excludesCannabis             Boolean
  cannabisPolicyCitation       String?
  supportsElectronicSubmission Boolean                 @default(true)
  attachmentChannels           String[]                @default([]) // {pwk_electronic, fax, mail, portal}
  /// Drives the "rule out of date" banner when > 6 months old.
  lastReviewedAt               DateTime                @default(now())
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt

  organization Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  auditLogs    PayerRuleAuditLog[]

  @@unique([organizationId, id])
  @@index([organizationId])
}

/// Append-only edit log for PayerRule. Captures full before/after JSON
/// snapshots so an admin can reconstruct any prior rule state.
model PayerRuleAuditLog {
  id             String   @id @default(cuid())
  payerRuleId    String
  organizationId String?
  editedById     String?
  editedAt       DateTime @default(now())
  before         Json
  after          Json
  changedFields  String[] @default([])
  reason         String?

  payerRule PayerRule @relation(fields: [payerRuleId], references: [id], onDelete: Cascade)

  @@index([payerRuleId, editedAt])
}

/// EMR-222 — NCCI Procedure-to-Procedure (PTP) edit pair. CMS publishes
/// quarterly. Tagged with the quarter version string so an admin can
/// answer "which quarter adjudicated this claim?".
model NcciEdit {
  id                String    @id @default(cuid())
  column1Code       String
  column2Code       String
  modifierIndicator Int // 0=no override, 1=override allowed, 9=N/A
  rationale         String?
  effectiveDate     DateTime
  deletionDate      DateTime?
  quarter           String // "2026Q2"
  loadedAt          DateTime  @default(now())

  @@unique([column1Code, column2Code, quarter])
  @@index([column1Code])
  @@index([quarter])
}

/// EMR-222 — Medically Unlikely Edit. Maximum units of service CMS
/// expects on a single date of service for a given HCPCS code.
model MueLimit {
  id            String   @id @default(cuid())
  hcpcsCode     String
  mueValue      Int
  adjudication  Int // 1=line, 2=date-of-service, 3=clinical
  rationale     String?
  effectiveDate DateTime
  quarter       String
  loadedAt      DateTime @default(now())

  @@unique([hcpcsCode, quarter])
  @@index([hcpcsCode])
  @@index([quarter])
}

/// Tracks the most-recently loaded NCCI/MUE quarter so the scrub engine
/// can surface "loaded quarter" + the admin UI can show staleness.
model NcciMueLoadStatus {
  id         String   @id @default(cuid())
  table      String   @unique // "ncci" | "mue"
  quarter    String
  rowCount   Int
  source     String?
  loadedAt   DateTime @default(now())
  loadedById String?
}

/// EMR-217 — Permanent-failure submissions. Auth that won't recover,
/// malformed gateway response, or rate-limit exhaustion across N attempts.
/// Operators investigate from /ops/billing/dead-letter and resolve.
model ClearinghouseDeadLetter {
  id              String    @id @default(cuid())
  submissionId    String?
  claimId         String?
  organizationId  String
  gatewayName     String // "availity" | "waystar" | etc.
  failureCategory String // "network" | "timeout" | "malformed_response" | "auth" | "rate_limit_exhausted" | "permanent_rejection"
  errorMessage    String
  requestPayload  String? // EDI payload at the moment of failure
  responseBody    String?
  attemptCount    Int       @default(1)
  firstFailedAt   DateTime  @default(now())
  lastFailedAt    DateTime  @default(now())
  resolvedAt      DateTime?
  resolvedById    String?
  resolutionNote  String?

  @@index([organizationId, resolvedAt])
  @@index([claimId])
}
