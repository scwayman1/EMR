// Canonical data model for the AI-Native Cannabis Care Platform.
//
// Design rules:
//   1. Favor structured columns; fall back to JSONB only when the shape
//      is genuinely open (note blocks, intake answers, agent payloads).
//   2. Every sensitive action writes an AuditLog row.
//   3. Every async operation goes through AgentJob — one queue to rule them all.
//   4. Soft-delete by default for patient-owned data via `deletedAt`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------------
// Identity & Org
// --------------------------------------------------------------

enum Role {
  patient
  clinician
  operator
  practice_owner
  system
}

model Organization {
  id             String       @id @default(cuid())
  name           String
  slug           String       @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  memberships    Membership[]
  patients       Patient[]
  providers      Provider[]
  encounters     Encounter[]
  documents      Document[]
  auditLogs      AuditLog[]
  agentJobs      AgentJob[]
  launchStatus   PracticeLaunchStatus?
  products       Product[]
  orders         Order[]
  shifts         Shift[]
  timeEntries    TimeEntry[]
  trainingModules TrainingModule[]
  incidents      Incident[]
  vendors        Vendor[]
  campaigns      MarketingCampaign[]
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  passwordHash   String
  firstName      String
  lastName       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  lastLoginAt    DateTime?

  memberships    Membership[]
  patientProfile Patient?     @relation("PatientUser")
  providerProfile Provider?   @relation("ProviderUser")
  sentMessages   Message[]    @relation("MessageSender")
  auditLogs      AuditLog[]
  approvedJobs   AgentJob[]   @relation("JobApprovedBy")
  shifts         Shift[]      @relation("ShiftAssignee")
  timeEntries    TimeEntry[]  @relation("TimeEntryUser")
  trainingCompletions TrainingCompletion[] @relation("TrainingCompletionUser")
  reportedIncidents Incident[] @relation("IncidentReporter")
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, role])
  @@index([organizationId, role])
}

// --------------------------------------------------------------
// Patient & Provider
// --------------------------------------------------------------

enum PatientStatus {
  prospect
  active
  inactive
  archived
}

enum QualificationStatus {
  unknown
  pending
  qualified
  ineligible
  expired
}

model Patient {
  id              String              @id @default(cuid())
  userId          String?             @unique
  organizationId  String
  status          PatientStatus       @default(prospect)
  // Demographics
  firstName       String
  lastName        String
  dateOfBirth     DateTime?
  email           String?
  phone           String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  postalCode      String?
  // Cannabis + clinical
  intakeAnswers   Json?               // progressive intake payload
  cannabisHistory Json?               // prior use, formats, benefits, side effects
  presentingConcerns String?
  treatmentGoals  String?
  qualificationStatus QualificationStatus @default(unknown)
  qualificationExpiresAt DateTime?
  // Soft delete
  deletedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user            User?               @relation("PatientUser", fields: [userId], references: [id])
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chartSummary    ChartSummary?
  encounters      Encounter[]
  documents       Document[]
  assessmentResponses AssessmentResponse[]
  outcomeLogs     OutcomeLog[]
  messageThreads  MessageThread[]
  appointments    Appointment[]
  tasks           Task[]
  orders          Order[]
  productReviews  ProductReview[]

  @@index([organizationId, status])
  @@index([lastName, firstName])
}

model Provider {
  id              String       @id @default(cuid())
  userId          String       @unique
  organizationId  String
  title           String?      // e.g. "MD, Integrative Oncology"
  specialties     String[]     @default([])
  bio             String?
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())

  user            User         @relation("ProviderUser", fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  encounters      Encounter[]
  appointments    Appointment[]

  @@index([organizationId])
}

// --------------------------------------------------------------
// Chart readiness summary (written by Intake Agent)
// --------------------------------------------------------------

model ChartSummary {
  id             String   @id @default(cuid())
  patientId      String   @unique
  summaryMd      String   // markdown
  completenessScore Int   // 0-100
  missingFields  String[] @default([])
  generatedBy    String   // agent name:version
  generatedAt    DateTime @default(now())

  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------------
// Documents
// --------------------------------------------------------------

enum DocumentKind {
  note
  lab
  image
  diagnosis
  letter
  other
  unclassified
}

model Document {
  id             String       @id @default(cuid())
  organizationId String
  patientId      String
  uploadedById   String?
  kind           DocumentKind @default(unclassified)
  originalName   String
  mimeType       String
  sizeBytes      Int
  storageKey     String       // opaque pointer to object storage
  tags           String[]     @default([])
  aiClassified   Boolean      @default(false)
  aiTags         String[]     @default([])
  aiConfidence   Float?
  needsReview    Boolean      @default(false)
  encounterId    String?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter      Encounter?   @relation(fields: [encounterId], references: [id])

  @@index([patientId, kind])
  @@index([organizationId, needsReview])
}

// --------------------------------------------------------------
// Encounters & Notes
// --------------------------------------------------------------

enum EncounterStatus {
  scheduled
  in_progress
  complete
  cancelled
}

model Encounter {
  id             String          @id @default(cuid())
  organizationId String
  patientId      String
  providerId     String?
  status         EncounterStatus @default(scheduled)
  scheduledFor   DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  modality       String          @default("in_person") // in_person | video | phone
  reason         String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient        Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  provider       Provider?       @relation(fields: [providerId], references: [id])
  notes          Note[]
  documents      Document[]

  @@index([patientId, status])
  @@index([providerId, scheduledFor])
}

enum NoteStatus {
  draft
  needs_review
  finalized
  amended
}

model Note {
  id             String     @id @default(cuid())
  encounterId    String
  authorUserId   String?    // null when drafted by agent, set when finalized by clinician
  status         NoteStatus @default(draft)
  // Structured note blocks — see src/lib/domain/notes.ts for the canonical block types.
  blocks         Json
  narrative      String?    // free-form fallback text
  aiDrafted      Boolean    @default(false)
  aiConfidence   Float?
  finalizedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  encounter      Encounter  @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  codingSuggestion CodingSuggestion?

  @@index([encounterId, status])
}

model CodingSuggestion {
  id             String   @id @default(cuid())
  noteId         String   @unique
  icd10          Json     // [{ code, label, confidence }]
  emLevel        String?
  rationale      String?
  generatedAt    DateTime @default(now())

  note           Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------------
// Assessments & Outcomes
// --------------------------------------------------------------

model Assessment {
  id             String   @id @default(cuid())
  slug           String   @unique // "phq-9", "gad-7", "pain-vas"
  title          String
  description    String?
  // Form schema — see src/lib/domain/assessments.ts
  schema         Json
  scoringRules   Json?
  createdAt      DateTime @default(now())

  responses      AssessmentResponse[]
}

model AssessmentResponse {
  id             String   @id @default(cuid())
  assessmentId   String
  patientId      String
  answers        Json
  score          Float?
  interpretation String?
  submittedAt    DateTime @default(now())

  assessment     Assessment @relation(fields: [assessmentId], references: [id])
  patient        Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, submittedAt])
}

enum OutcomeMetric {
  pain
  sleep
  anxiety
  mood
  nausea
  appetite
  energy
  adherence
  side_effects
}

model OutcomeLog {
  id             String        @id @default(cuid())
  patientId      String
  metric         OutcomeMetric
  value          Float         // normalized 0-10
  note           String?
  loggedAt       DateTime      @default(now())

  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, metric, loggedAt])
}

// --------------------------------------------------------------
// Messaging
// --------------------------------------------------------------

model MessageThread {
  id             String    @id @default(cuid())
  patientId      String
  subject        String
  lastMessageAt  DateTime  @default(now())
  createdAt      DateTime  @default(now())

  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@index([patientId, lastMessageAt])
}

enum MessageStatus {
  draft
  sent
  read
}

model Message {
  id             String        @id @default(cuid())
  threadId       String
  senderUserId   String?       // null when agent-drafted
  senderAgent    String?       // agent name:version if AI-drafted
  status         MessageStatus @default(draft)
  body           String
  aiDrafted      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  sentAt         DateTime?

  thread         MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender         User?         @relation("MessageSender", fields: [senderUserId], references: [id])

  @@index([threadId, createdAt])
}

// --------------------------------------------------------------
// Scheduling
// --------------------------------------------------------------

enum AppointmentStatus {
  requested
  confirmed
  cancelled
  completed
  no_show
}

model Appointment {
  id             String            @id @default(cuid())
  patientId      String
  providerId     String?
  status         AppointmentStatus @default(requested)
  startAt        DateTime
  endAt          DateTime
  modality       String            @default("video")
  notes          String?
  createdAt      DateTime          @default(now())

  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  provider       Provider? @relation(fields: [providerId], references: [id])

  @@index([providerId, startAt])
  @@index([patientId, startAt])
}

// --------------------------------------------------------------
// Tasks (human or agent-owned work items)
// --------------------------------------------------------------

enum TaskStatus {
  open
  in_progress
  done
  snoozed
  cancelled
}

model Task {
  id             String     @id @default(cuid())
  organizationId String
  patientId      String?
  title          String
  description    String?
  status         TaskStatus @default(open)
  assigneeRole   Role?
  assigneeUserId String?
  dueAt          DateTime?
  createdAt      DateTime   @default(now())
  completedAt    DateTime?

  patient        Patient?   @relation(fields: [patientId], references: [id])

  @@index([organizationId, status])
  @@index([assigneeUserId, status])
}

// --------------------------------------------------------------
// Orchestration queue
// --------------------------------------------------------------

enum AgentJobStatus {
  pending
  claimed
  running
  needs_approval
  succeeded
  failed
  cancelled
}

model AgentJob {
  id             String         @id @default(cuid())
  organizationId String?
  workflowName   String
  agentName      String
  eventName      String
  input          Json
  output         Json?
  status         AgentJobStatus @default(pending)
  attempts       Int            @default(0)
  maxAttempts    Int            @default(3)
  lastError      String?
  logs           Json           @default("[]")
  requiresApproval Boolean      @default(false)
  approvalRequiredAt DateTime?
  approvedById   String?
  approvedAt     DateTime?
  claimedAt      DateTime?
  claimedBy      String?        // worker id
  runAfter       DateTime       @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime       @default(now())

  organization   Organization?  @relation(fields: [organizationId], references: [id])
  approvedBy     User?          @relation("JobApprovedBy", fields: [approvedById], references: [id])

  @@index([status, runAfter])
  @@index([organizationId, status])
  @@index([workflowName, status])
}

// --------------------------------------------------------------
// Audit log (append-only)
// --------------------------------------------------------------

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  actorUserId    String?
  actorAgent     String?  // "agent:scribe@1.0.0"
  action         String   // e.g. "patient.read", "note.finalized"
  subjectType    String?
  subjectId      String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization   Organization? @relation(fields: [organizationId], references: [id])
  actor          User?         @relation(fields: [actorUserId], references: [id])

  @@index([organizationId, createdAt])
  @@index([subjectType, subjectId])
}

// --------------------------------------------------------------
// Research (stubbed for V1)
// --------------------------------------------------------------

model ResearchQuery {
  id             String   @id @default(cuid())
  userId         String?
  patientId      String?
  queryText      String
  createdAt      DateTime @default(now())

  results        ResearchResult[]

  @@index([userId, createdAt])
}

model ResearchResult {
  id             String   @id @default(cuid())
  queryId        String
  title          String
  source         String
  year           Int?
  summary        String
  citation       String
  quantitativeFindings Json?
  rank           Int      @default(0)

  query          ResearchQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------------
// Practice launch readiness
// --------------------------------------------------------------

model PracticeLaunchStatus {
  id             String   @id @default(cuid())
  organizationId String   @unique
  readinessScore Int      @default(0)
  blockers       Json     @default("[]")
  nextSteps      Json     @default("[]")
  goLiveAt       DateTime?
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------------
// Leafjourney Marketplace
// --------------------------------------------------------------

enum ProductStatus {
  draft
  active
  archived
  out_of_stock
}

model Product {
  id                String        @id @default(cuid())
  organizationId    String
  name              String
  slug              String        @unique
  brand             String
  description       String
  shortDescription  String?
  price             Float
  compareAtPrice    Float?
  status            ProductStatus @default(draft)
  format            String        // tincture, flower, edible, topical, capsule, vape
  imageUrl          String?
  images            String[]      @default([])

  // Cannabinoid profile
  thcContent        Float?
  cbdContent        Float?
  cbnContent        Float?
  thcvContent       Float?
  terpeneProfile    Json?
  strainType        String?       // indica, sativa, hybrid, n/a

  // Use-case metadata
  symptoms          String[]      @default([])
  goals             String[]      @default([])
  useCases          String[]      @default([])
  onsetTime         String?
  duration          String?

  // Dosage
  dosageGuidance    String?
  beginnerFriendly  Boolean       @default(false)

  // Trust
  labVerified       Boolean       @default(false)
  coaUrl            String?
  clinicianPick     Boolean       @default(false)
  clinicianNote     String?

  // Inventory
  inStock           Boolean       @default(true)
  inventoryCount    Int           @default(0)

  // Ratings
  averageRating     Float         @default(0)
  reviewCount       Int           @default(0)

  // Ordering + features
  sortOrder         Int           @default(0)
  featured          Boolean       @default(false)

  deletedAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  variants          ProductVariant[]
  reviews           ProductReview[]
  orderItems        OrderItem[]
  categoryMappings  ProductCategory[]

  @@index([organizationId, status])
  @@index([clinicianPick])
  @@index([featured])
}

model ProductVariant {
  id              String    @id @default(cuid())
  productId       String
  name            String
  sku             String?
  price           Float
  compareAtPrice  Float?
  inStock         Boolean   @default(true)
  inventoryCount  Int       @default(0)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())

  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]

  @@index([productId])
}

model MarketplaceCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  type        String    @default("standard") // standard, symptom, goal, format
  imageUrl    String?
  icon        String?
  sortOrder   Int       @default(0)
  parentId    String?
  createdAt   DateTime  @default(now())

  parent      MarketplaceCategory?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    MarketplaceCategory[] @relation("CategoryChildren")
  products    ProductCategory[]

  @@index([type])
  @@index([parentId])
}

model ProductCategory {
  id          String @id @default(cuid())
  productId   String
  categoryId  String

  product     Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  category    MarketplaceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
}

model ProductReview {
  id          String    @id @default(cuid())
  productId   String
  patientId   String?
  authorName  String
  rating      Int
  title       String?
  body        String?
  verified    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  patient     Patient?  @relation(fields: [patientId], references: [id])

  @@index([productId, createdAt])
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

model Order {
  id              String      @id @default(cuid())
  organizationId  String
  patientId       String
  status          OrderStatus @default(pending)
  subtotal        Float
  tax             Float       @default(0)
  total           Float
  notes           String?
  shippingAddress Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient         Patient      @relation(fields: [patientId], references: [id])
  items           OrderItem[]

  @@index([patientId, createdAt])
  @@index([organizationId, status])
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  productId   String
  variantId   String?
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  createdAt   DateTime        @default(now())

  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

// --------------------------------------------------------------
// Operations: staff schedule, time clock, training,
// incidents, vendors, marketing.
//
// These models power the /ops suite. They are intentionally lean
// — the goal is to make each surface usable end-to-end without
// pretending to be a full HRIS / EHS / CRM.
// --------------------------------------------------------------

enum ShiftStatus {
  scheduled
  in_progress
  completed
  cancelled
  no_show
}

model Shift {
  id             String       @id @default(cuid())
  organizationId String
  assigneeUserId String?
  role           String       // free-form job function: "front desk", "intake", "medical"
  startAt        DateTime
  endAt          DateTime
  status         ShiftStatus  @default(scheduled)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignee       User?        @relation("ShiftAssignee", fields: [assigneeUserId], references: [id])

  @@index([organizationId, startAt])
  @@index([assigneeUserId, startAt])
}

enum TimeEntryStatus {
  open
  closed
  adjusted
}

model TimeEntry {
  id             String          @id @default(cuid())
  organizationId String
  userId         String
  clockInAt      DateTime        @default(now())
  clockOutAt     DateTime?
  status         TimeEntryStatus @default(open)
  notes          String?
  // Denormalized minutes worked, set when the entry closes.
  minutesWorked  Int?
  createdAt      DateTime        @default(now())

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User            @relation("TimeEntryUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([userId, clockInAt])
}

model TrainingModule {
  id              String   @id @default(cuid())
  organizationId  String
  title           String
  description     String?
  durationMinutes Int      @default(15)
  required        Boolean  @default(false)
  topics          String[] @default([])
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  completions     TrainingCompletion[]

  @@index([organizationId, active])
}

model TrainingCompletion {
  id          String   @id @default(cuid())
  moduleId    String
  userId      String
  completedAt DateTime @default(now())
  score       Int?
  notes       String?

  module      TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user        User           @relation("TrainingCompletionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([moduleId, userId])
  @@index([userId, completedAt])
}

enum IncidentSeverity {
  low
  medium
  high
  critical
}

enum IncidentStatus {
  open
  investigating
  resolved
  closed
}

model Incident {
  id               String           @id @default(cuid())
  organizationId   String
  reportedByUserId String?
  occurredAt       DateTime
  category         String           // "safety", "privacy", "clinical", "facilities", "other"
  severity         IncidentSeverity @default(low)
  status           IncidentStatus   @default(open)
  summary          String
  resolution       String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reportedBy       User?        @relation("IncidentReporter", fields: [reportedByUserId], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, severity])
}

enum VendorStatus {
  active
  inactive
  on_hold
}

model Vendor {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  category       String       // "supplier", "lab", "it", "legal", "marketing", "other"
  status         VendorStatus @default(active)
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  website        String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([organizationId, category])
}

enum CampaignStatus {
  draft
  scheduled
  live
  paused
  completed
}

enum CampaignChannel {
  email
  sms
  social
  print
  referral
  event
  other
}

model MarketingCampaign {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  channel        CampaignChannel
  status         CampaignStatus  @default(draft)
  audience       String?
  goal           String?
  startAt        DateTime?
  endAt          DateTime?
  budget         Float?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([organizationId, channel])
}
