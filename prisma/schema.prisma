// Canonical data model for the AI-Native Cannabis Care Platform.
//
// Design rules:
//   1. Favor structured columns; fall back to JSONB only when the shape
//      is genuinely open (note blocks, intake answers, agent payloads).
//   2. Every sensitive action writes an AuditLog row.
//   3. Every async operation goes through AgentJob — one queue to rule them all.
//   4. Soft-delete by default for patient-owned data via `deletedAt`.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  // Runtime query URL — points at Supabase's PgBouncer pooler (port 6543).
  url       = env("DATABASE_URL")
  // Schema-change URL — direct connection (port 5432). Prisma uses this
  // for `migrate deploy` / `db push` / `introspect` because those need
  // advisory locks that PgBouncer drops. Falls back to `url` if unset
  // locally; prod MUST have this set.
  directUrl = env("DIRECT_URL")
}

// --------------------------------------------------------------
// Identity & Org
// --------------------------------------------------------------

enum Role {
  patient
  clinician
  operator
  practice_owner
  system
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships       Membership[]
  patients          Patient[]
  providers         Provider[]
  encounters        Encounter[]
  documents         Document[]
  labResults        LabResult[]
  refillRequests    RefillRequest[]
  auditLogs         AuditLog[]
  agentJobs         AgentJob[]
  agentFeedback     AgentFeedback[]
  escalationCases   EscalationCase[]
  launchStatus      PracticeLaunchStatus?
  cannabisProducts  CannabisProduct[]
  claims            Claim[]
  feeSchedule       FeeScheduleEntry[]
  referrals         Referral[]
  complianceForms   StateComplianceForm[]
  intakeTemplates   IntakeFormTemplate[]
  products          Product[]
  orders            Order[]
  vendors           Vendor[]
  vendorDocuments   VendorDocument[]
  // CFO / Controller surface
  expenses          Expense[]
  recurringExpenses RecurringExpense[]
  bankAccounts      BankAccount[]
  cashFlowEntries   CashFlowEntry[]
  fixedAssets       FixedAsset[]
  liabilities       Liability[]
  equityEntries     EquityEntry[]
  financialReports  FinancialReport[]
  financialGoals    FinancialGoal[]
}

model User {
  id           String    @id @default(cuid())
  clerkId      String?   @unique // Clerk user ID — populated when using Clerk auth
  email        String    @unique
  passwordHash String    @default("") // legacy: empty string when user is Clerk-managed
  firstName    String
  lastName     String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  memberships             Membership[]
  patientProfile          Patient?                 @relation("PatientUser")
  providerProfile         Provider?                @relation("ProviderUser")
  sentMessages            Message[]                @relation("MessageSender")
  auditLogs               AuditLog[]
  approvedJobs            AgentJob[]               @relation("JobApprovedBy")
  notifications           Notification[]
  communicationPreference CommunicationPreference?
  signedLabResults        LabResult[]              @relation("LabResultSigner")
  approvedLabOutreach     LabOutreach[]            @relation("LabOutreachApprover")
  signedRefills           RefillRequest[]          @relation("RefillSigner")
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           Role
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, role])
  @@index([organizationId, role])
}

// --------------------------------------------------------------
// Patient & Provider
// --------------------------------------------------------------

enum PatientStatus {
  prospect
  active
  inactive
  archived
}

enum QualificationStatus {
  unknown
  pending
  qualified
  ineligible
  expired
}

model Patient {
  id                     String              @id @default(cuid())
  userId                 String?             @unique
  organizationId         String
  status                 PatientStatus       @default(prospect)
  // Demographics
  firstName              String
  lastName               String
  dateOfBirth            DateTime?
  ageVerifiedAt          DateTime?
  email                  String?
  phone                  String?
  addressLine1           String?
  addressLine2           String?
  city                   String?
  state                  String?
  postalCode             String?
  // Cannabis + clinical
  intakeAnswers          Json? // progressive intake payload
  cannabisHistory        Json? // prior use, formats, benefits, side effects
  presentingConcerns     String?
  treatmentGoals         String?
  // Clinical safety fields (EMR-113)
  allergies              String[]            @default([]) // e.g. ["Penicillin", "Sulfa", "Latex"]
  contraindications      String[]            @default([]) // e.g. ["MAOIs", "Blood thinners"]
  qualificationStatus    QualificationStatus @default(unknown)
  qualificationExpiresAt DateTime?
  // Soft delete
  deletedAt              DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  user                 User?                 @relation("PatientUser", fields: [userId], references: [id])
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chartSummary         ChartSummary?
  encounters           Encounter[]
  documents            Document[]
  labResults           LabResult[]
  refillRequests       RefillRequest[]
  assessmentResponses  AssessmentResponse[]
  outcomeLogs          OutcomeLog[]
  messageThreads       MessageThread[]
  appointments         Appointment[]
  tasks                Task[]
  dosingRegimens       DosingRegimen[]
  doseLogs             DoseLog[]
  medications          PatientMedication[]
  claims               Claim[]
  financialEvents      FinancialEvent[]
  statements           Statement[]
  paymentPlans         PaymentPlan[]
  coverages            PatientCoverage[]
  paymentMethods       StoredPaymentMethod[]
  charges              Charge[]
  eligibilitySnapshots EligibilitySnapshot[]
  // Agentic memory harness
  memories             PatientMemory[]
  observations         ClinicalObservation[]
  referrals            Referral[]
  signedConsents       SignedConsent[]
  complianceForms      StateComplianceForm[]
  caregiverInvites     CaregiverInvite[]
  surveySubmissions    SurveySubmission[]
  // Marketplace
  orders               Order[]
  productReviews       ProductReview[]
  cart                 Cart?
  shippingAddresses    ShippingAddress[]

  @@index([organizationId, status])
  @@index([lastName, firstName])
}

// --------------------------------------------------------------
// Saved shipping addresses — Leafmart account → checkout autofill.
// Patient.addressLine1/2/etc. is the *primary* address from intake;
// ShippingAddress is a multi-row book a customer can manage and pick
// from at checkout.
// --------------------------------------------------------------
model ShippingAddress {
  id         String   @id @default(cuid())
  patientId  String
  label      String? // "Home", "Work", etc.
  firstName  String
  lastName   String
  address1   String
  address2   String?
  city       String
  state      String
  postalCode String
  phone      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, isDefault])
}

model Provider {
  id             String   @id @default(cuid())
  userId         String   @unique
  organizationId String
  title          String? // e.g. "MD, Integrative Oncology"
  specialties    String[] @default([])
  bio            String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  user         User          @relation("ProviderUser", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  encounters   Encounter[]
  appointments Appointment[]
  claims       Claim[]

  @@index([organizationId])
}

// --------------------------------------------------------------
// Chart readiness summary (written by Intake Agent)
// --------------------------------------------------------------

model ChartSummary {
  id                String   @id @default(cuid())
  patientId         String   @unique
  summaryMd         String // markdown
  completenessScore Int // 0-100
  missingFields     String[] @default([])
  generatedBy       String // agent name:version
  generatedAt       DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------------
// Documents
// --------------------------------------------------------------

enum DocumentKind {
  note
  lab
  image
  diagnosis
  letter
  other
  unclassified
}

model Document {
  id             String       @id @default(cuid())
  organizationId String
  patientId      String
  uploadedById   String?
  kind           DocumentKind @default(unclassified)
  originalName   String
  mimeType       String
  sizeBytes      Int
  storageKey     String // opaque pointer to object storage
  tags           String[]     @default([])
  aiClassified   Boolean      @default(false)
  aiTags         String[]     @default([])
  aiConfidence   Float?
  needsReview    Boolean      @default(false)
  encounterId    String?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter    Encounter?   @relation(fields: [encounterId], references: [id])

  @@index([patientId, kind])
  @@index([organizationId, needsReview])
}

// --------------------------------------------------------------
// Encounters & Notes
// --------------------------------------------------------------

enum EncounterStatus {
  scheduled
  in_progress
  complete
  cancelled
}

model Encounter {
  id                  String          @id @default(cuid())
  organizationId      String
  patientId           String
  providerId          String?
  status              EncounterStatus @default(scheduled)
  scheduledFor        DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  chartingCompletedAt DateTime? // When the physician finalized all notes for this encounter. NULL while documentation is still in draft / incomplete.
  modality            String          @default("in_person") // in_person | video | phone
  placeOfService      String? // 2-digit POS code: 11=office, 02=telehealth
  renderingProviderId String? // if different from scheduling provider
  reason              String?
  briefingContext     Json? // Pre-visit intelligence briefing (talking points, risk flags, summary)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient           Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  provider          Provider?          @relation(fields: [providerId], references: [id], onDelete: SetNull)
  notes             Note[]
  documents         Document[]
  claims            Claim[]
  charges           Charge[]
  surveySubmissions SurveySubmission[]

  @@index([patientId, status])
  @@index([providerId, scheduledFor])
  @@index([organizationId, status, createdAt])
}

enum NoteStatus {
  draft
  needs_review
  finalized
  amended
}

model Note {
  id           String     @id @default(cuid())
  encounterId  String
  authorUserId String? // null when drafted by agent, set when finalized by clinician
  status       NoteStatus @default(draft)
  // Structured note blocks — see src/lib/domain/notes.ts for the canonical block types.
  blocks       Json
  narrative    String? // free-form fallback text
  aiDrafted    Boolean    @default(false)
  aiConfidence Float?
  finalizedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  encounter        Encounter         @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  codingSuggestion CodingSuggestion?

  @@index([encounterId, status])
}

model CodingSuggestion {
  id          String   @id @default(cuid())
  noteId      String   @unique
  icd10       Json // [{ code, label, confidence }]
  emLevel     String?
  rationale   String?
  generatedAt DateTime @default(now())

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------------
// Billing — Claims, Payments, Fee Schedule
// --------------------------------------------------------------

enum ClaimStatus {
  draft // not yet submitted
  scrubbing // being validated pre-submission
  scrub_blocked // scrub found blocking issues
  ready // scrub passed, awaiting submission
  submitted // sent to clearinghouse
  ch_rejected // clearinghouse returned rejection
  pending // (deprecated — use accepted/adjudicated. Kept for existing data migration)
  accepted // payer acknowledged receipt
  adjudicated // payer made a decision
  paid // fully paid
  partial // partially paid, balance due
  denied // payer denied
  appealed // under appeal
  closed // financial closure reached
  voided // voided (error/duplicate)
  written_off // written off
}

model Claim {
  id                   String      @id @default(cuid())
  organizationId       String
  patientId            String
  encounterId          String?
  providerId           String?
  status               ClaimStatus @default(draft)
  // Coding
  cptCodes             Json // [{ code, label, units, chargeAmount }]
  icd10Codes           Json // [{ code, label }]
  // Financials (in cents to avoid float rounding)
  billedAmountCents    Int
  allowedAmountCents   Int?
  paidAmountCents      Int         @default(0)
  patientRespCents     Int         @default(0)
  // Payer
  payerName            String? // "Blue Cross Blue Shield", "Aetna", etc.
  payerId              String? // standardized EDI payer ID
  claimNumber          String? // our internal claim number
  // Provider identifiers for 837P
  billingNpi           String? // billing provider NPI
  renderingNpi         String? // rendering provider NPI (may differ)
  placeOfService       String? // 2-digit POS code (11=office, 02=telehealth)
  // Submission control
  frequencyCode        String? // 1=original, 7=replacement, 8=void
  priorAuthNumber      String? // prior authorization reference
  timelyFilingDeadline DateTime? // computed from payer rules
  resubmissionCount    Int         @default(0)
  // Lifecycle
  serviceDate          DateTime
  submittedAt          DateTime?
  paidAt               DateTime?
  deniedAt             DateTime?
  denialReason         String?
  closedAt             DateTime?
  closureType          String? // paid_in_full, written_off, patient_on_plan, collections, voided, adjusted
  notes                String?
  // Agent-written: scrub issues from Claims Scrubbing Agent
  scrubIssues          Json?
  scrubbedAt           DateTime?
  // Agent-written: denial triage from Denial Resolution Agent
  denialTriage         Json?
  triagedAt            DateTime?
  // Tracking
  humanTouches         Int         @default(0) // count of human interventions on this claim
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  organization    Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient         Patient                   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter       Encounter?                @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  provider        Provider?                 @relation(fields: [providerId], references: [id], onDelete: SetNull)
  payments        Payment[]
  financialEvents FinancialEvent[]
  charges         Charge[]
  scrubResults    ClaimScrubResult[]
  submissions     ClearinghouseSubmission[]
  adjudications   AdjudicationResult[]
  denialEvents    DenialEvent[]
  appealPackets   AppealPacket[]
  adjustments     Adjustment[]

  @@index([organizationId, status, serviceDate])
  @@index([patientId, serviceDate])
  @@index([providerId, serviceDate])
  @@index([status, timelyFilingDeadline])
}

enum PaymentSource {
  patient
  insurance
  adjustment
}

model Payment {
  id          String        @id @default(cuid())
  claimId     String
  source      PaymentSource
  amountCents Int
  paymentDate DateTime      @default(now())
  reference   String? // check #, EFT trace, last4 of card
  notes       String?

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId, paymentDate])
}

// --------------------------------------------------------------
// RCM Fleet — New billing models (Layer 2)
// --------------------------------------------------------------

enum ChargeStatus {
  pending // created, not yet on a claim
  claim_attached // linked to a claim line
  voided // cancelled
}

model Charge {
  id             String       @id @default(cuid())
  encounterId    String
  patientId      String
  organizationId String
  cptCode        String // e.g. "99214", "36415"
  cptDescription String?
  modifiers      String[]     @default([]) // e.g. ["25", "XE"]
  units          Int          @default(1)
  icd10Codes     String[]     @default([]) // linked diagnosis codes
  feeAmountCents Int // from fee schedule
  status         ChargeStatus @default(pending)
  claimId        String? // set when attached to a claim
  confidence     Float? // coding confidence (0-1)
  createdBy      String // agent name or user id
  createdAt      DateTime     @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  claim     Claim?    @relation(fields: [claimId], references: [id], onDelete: SetNull)

  @@index([encounterId])
  @@index([patientId, createdAt])
  @@index([claimId])
}

model EligibilitySnapshot {
  id                       String   @id @default(cuid())
  patientId                String
  coverageId               String
  checkedAt                DateTime @default(now())
  eligible                 Boolean
  planStatus               String // active, termed, pending
  copayAmountCents         Int?
  deductibleRemainingCents Int?
  oopRemainingCents        Int?
  coinsurancePct           Int?
  priorAuthRequired        Boolean  @default(false)
  referralRequired         Boolean  @default(false)
  networkStatus            String   @default("unknown") // in_network, out_of_network, unknown
  rawResponse              Json? // full 271 response for audit
  expiresAt                DateTime // when this snapshot is stale (default: +24h)
  createdAt                DateTime @default(now())

  patient  Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  coverage PatientCoverage @relation(fields: [coverageId], references: [id], onDelete: Cascade)

  @@index([patientId, coverageId, checkedAt])
  @@index([expiresAt])
}

enum ScrubStatus {
  clean
  warnings
  blocked
}

model ClaimScrubResult {
  id               String      @id @default(cuid())
  claimId          String
  scrubVersion     String // agent version that performed the scrub
  status           ScrubStatus
  edits            Json        @default("[]") // [{ ruleId, severity, message, lineSequence, autoFixApplied }]
  ncciConflicts    Json        @default("[]") // detected NCCI edit pairs
  modifierWarnings Json        @default("[]")
  missingFields    Json        @default("[]")
  scrubbedAt       DateTime    @default(now())

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId, scrubbedAt])
}

enum SubmissionResponseStatus {
  pending
  accepted
  rejected
}

model ClearinghouseSubmission {
  id                String                   @id @default(cuid())
  claimId           String
  organizationId    String
  clearinghouseName String // "Availity", "Waystar", etc.
  submittedAt       DateTime                 @default(now())
  ediPayload        String? // 837P payload (stored for audit)
  responseStatus    SubmissionResponseStatus @default(pending)
  responseCode      String?
  responseMessage   String?
  respondedAt       DateTime?
  retryCount        Int                      @default(0)

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId, submittedAt])
}

enum AdjudicationClaimStatus {
  paid
  denied
  partial
  pending_review
}

model AdjudicationResult {
  id                    String                  @id @default(cuid())
  claimId               String
  eraDate               DateTime // date ERA was received
  checkNumber           String? // payer payment reference
  totalPaidCents        Int                     @default(0)
  totalAllowedCents     Int                     @default(0)
  totalAdjustedCents    Int                     @default(0)
  totalPatientRespCents Int                     @default(0)
  claimStatus           AdjudicationClaimStatus
  lineDetails           Json                    @default("[]") // per-line: paid, allowed, CARC/RARC
  rawEra                String? // full 835 segment for audit
  parsedAt              DateTime                @default(now())

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
}

enum DenialResolution {
  pending
  corrected_and_resubmitted
  appealed
  written_off
  patient_responsibility
  overturned
  escalated
}

model DenialEvent {
  id                     String           @id @default(cuid())
  claimId                String
  claimLineSequence      Int? // null = claim-level denial
  carcCode               String // Claim Adjustment Reason Code (e.g. "16", "4", "197")
  rarcCode               String? // Remittance Advice Remark Code
  groupCode              String // CO, PR, OA, PI
  denialCategory         String? // agent-classified: coding_error, missing_info, eligibility, etc.
  amountDeniedCents      Int
  recoverable            Boolean          @default(true)
  recoverableAmountCents Int?
  resolution             DenialResolution @default(pending)
  resolvedAt             DateTime?
  createdAt              DateTime         @default(now())

  claim   Claim          @relation(fields: [claimId], references: [id], onDelete: Cascade)
  appeals AppealPacket[]

  @@index([claimId])
  @@index([carcCode, resolution])
  @@index([resolution, createdAt])
}

enum AppealStatus {
  draft
  approved_for_submission
  submitted
  overturned
  upheld
  pending_review
}

model AppealPacket {
  id                String       @id @default(cuid())
  claimId           String
  denialEventId     String
  appealLevel       Int          @default(1) // 1=first, 2=second, 3=external review
  appealLetter      String? // generated text
  supportingDocIds  String[]     @default([])
  submittedAt       DateTime?
  submittedTo       String? // payer address/fax/portal
  status            AppealStatus @default(draft)
  outcomeReceivedAt DateTime?
  generatedBy       String? // agent name
  reviewedBy        String? // user id (if human-reviewed)
  createdAt         DateTime     @default(now())

  claim       Claim       @relation(fields: [claimId], references: [id], onDelete: Cascade)
  denialEvent DenialEvent @relation(fields: [denialEventId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([status])
}

enum AdjustmentType {
  contractual
  write_off
  refund
  takeback
  courtesy
}

model Adjustment {
  id                String         @id @default(cuid())
  claimId           String
  claimLineSequence Int?
  type              AdjustmentType
  amountCents       Int // signed: negative = money back
  reason            String?
  carcCode          String? // if derived from ERA
  approvedBy        String? // user id (required for write-offs > $25)
  approvedAt        DateTime?
  postedAt          DateTime?
  createdAt         DateTime       @default(now())

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([type, createdAt])
}

enum EscalationTier {
  tier_1 // billing specialist
  tier_2 // compliance officer / senior biller
  tier_3 // practice owner
}

enum EscalationStatus {
  open
  assigned
  in_review
  resolved
  dismissed
}

model EscalationCase {
  id               String           @id @default(cuid())
  organizationId   String
  claimId          String?
  patientId        String?
  tier             EscalationTier
  category         String // coding_uncertainty, high_dollar, compliance_risk, etc.
  summary          String // agent-generated description
  sourceAgent      String // which agent escalated
  suggestedAction  String?
  assignedTo       String? // user id
  status           EscalationStatus @default(open)
  resolution       String? // what was decided
  resolvedAt       DateTime?
  resolvedBy       String? // user id
  feedbackRecorded Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, tier])
  @@index([claimId])
  @@index([status, createdAt])
}

model BillingMemory {
  id             String   @id @default(cuid())
  organizationId String
  scope          String // "payer" | "provider" | "patient" | "code_combo" | "global"
  scopeId        String? // payerId, providerId, patientId, or null for global
  category       String // "denial_pattern" | "modifier_rule" | "turnaround" | "collection_behavior" | "coding_pattern"
  content        String // narrative description
  confidence     Float    @default(0.8)
  evidenceCount  Int      @default(1)
  lastEvidenceAt DateTime @default(now())
  tags           String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([scope, scopeId, category])
  @@index([organizationId, category])
}

// --------------------------------------------------------------
// Fee schedule (existing)
// --------------------------------------------------------------

model FeeScheduleEntry {
  id                 String   @id @default(cuid())
  organizationId     String
  cptCode            String
  description        String
  defaultChargeCents Int
  category           String? // "E&M", "Procedure", "Cannabis Counseling", etc.
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, cptCode])
  @@index([organizationId, category])
}

// --------------------------------------------------------------
// Ledger, Statements, Payment Plans, Coverage
// --------------------------------------------------------------

enum FinancialEventType {
  charge_created
  charge_voided
  copay_assessed
  copay_collected
  claim_submitted
  claim_accepted
  claim_denied
  insurance_paid
  contractual_adjustment
  patient_responsibility_transferred
  patient_payment
  refund_issued
  credit_applied
  statement_issued
  statement_viewed
  payment_plan_created
  payment_plan_installment
  write_off
  chargeback
}

/// Every money-affecting event lands here as an immutable row.
/// amountCents is SIGNED: positive = money into practice, negative = money out/owed.
/// This is the source of truth for all balance calculations.
model FinancialEvent {
  id              String             @id @default(cuid())
  organizationId  String
  patientId       String
  claimId         String?
  encounterId     String?
  paymentId       String?
  type            FinancialEventType
  amountCents     Int // signed; + = cash in, - = cash out / balance owed
  description     String
