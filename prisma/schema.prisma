// Canonical data model for the AI-Native Cannabis Care Platform.
//
// Design rules:
//   1. Favor structured columns; fall back to JSONB only when the shape
//      is genuinely open (note blocks, intake answers, agent payloads).
//   2. Every sensitive action writes an AuditLog row.
//   3. Every async operation goes through AgentJob — one queue to rule them all.
//   4. Soft-delete by default for patient-owned data via `deletedAt`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------------
// Identity & Org
// --------------------------------------------------------------

enum Role {
  patient
  clinician
  operator
  practice_owner
  system
}

model Organization {
  id             String       @id @default(cuid())
  name           String
  slug           String       @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  memberships    Membership[]
  patients       Patient[]
  providers      Provider[]
  encounters     Encounter[]
  documents      Document[]
  auditLogs      AuditLog[]
  agentJobs      AgentJob[]
  launchStatus   PracticeLaunchStatus?
  cannabisProducts CannabisProduct[]
  claims         Claim[]
  feeSchedule    FeeScheduleEntry[]
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  passwordHash   String
  firstName      String
  lastName       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  lastLoginAt    DateTime?

  memberships    Membership[]
  patientProfile Patient?     @relation("PatientUser")
  providerProfile Provider?   @relation("ProviderUser")
  sentMessages   Message[]    @relation("MessageSender")
  auditLogs      AuditLog[]
  approvedJobs   AgentJob[]   @relation("JobApprovedBy")
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, role])
  @@index([organizationId, role])
}

// --------------------------------------------------------------
// Patient & Provider
// --------------------------------------------------------------

enum PatientStatus {
  prospect
  active
  inactive
  archived
}

enum QualificationStatus {
  unknown
  pending
  qualified
  ineligible
  expired
}

model Patient {
  id              String              @id @default(cuid())
  userId          String?             @unique
  organizationId  String
  status          PatientStatus       @default(prospect)
  // Demographics
  firstName       String
  lastName        String
  dateOfBirth     DateTime?
  email           String?
  phone           String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  postalCode      String?
  // Cannabis + clinical
  intakeAnswers   Json?               // progressive intake payload
  cannabisHistory Json?               // prior use, formats, benefits, side effects
  presentingConcerns String?
  treatmentGoals  String?
  qualificationStatus QualificationStatus @default(unknown)
  qualificationExpiresAt DateTime?
  // Soft delete
  deletedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user            User?               @relation("PatientUser", fields: [userId], references: [id])
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chartSummary    ChartSummary?
  encounters      Encounter[]
  documents       Document[]
  assessmentResponses AssessmentResponse[]
  outcomeLogs     OutcomeLog[]
  messageThreads  MessageThread[]
  appointments    Appointment[]
  tasks           Task[]
  dosingRegimens  DosingRegimen[]
  doseLogs        DoseLog[]
  medications     PatientMedication[]
  claims          Claim[]
  financialEvents FinancialEvent[]
  statements      Statement[]
  paymentPlans    PaymentPlan[]
  coverages       PatientCoverage[]
  paymentMethods  StoredPaymentMethod[]

  @@index([organizationId, status])
  @@index([lastName, firstName])
}

model Provider {
  id              String       @id @default(cuid())
  userId          String       @unique
  organizationId  String
  title           String?      // e.g. "MD, Integrative Oncology"
  specialties     String[]     @default([])
  bio             String?
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())

  user            User         @relation("ProviderUser", fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  encounters      Encounter[]
  appointments    Appointment[]
  claims          Claim[]

  @@index([organizationId])
}

// --------------------------------------------------------------
// Chart readiness summary (written by Intake Agent)
// --------------------------------------------------------------

model ChartSummary {
  id             String   @id @default(cuid())
  patientId      String   @unique
  summaryMd      String   // markdown
  completenessScore Int   // 0-100
  missingFields  String[] @default([])
  generatedBy    String   // agent name:version
  generatedAt    DateTime @default(now())

  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------------
// Documents
// --------------------------------------------------------------

enum DocumentKind {
  note
  lab
  image
  diagnosis
  letter
  other
  unclassified
}

model Document {
  id             String       @id @default(cuid())
  organizationId String
  patientId      String
  uploadedById   String?
  kind           DocumentKind @default(unclassified)
  originalName   String
  mimeType       String
  sizeBytes      Int
  storageKey     String       // opaque pointer to object storage
  tags           String[]     @default([])
  aiClassified   Boolean      @default(false)
  aiTags         String[]     @default([])
  aiConfidence   Float?
  needsReview    Boolean      @default(false)
  encounterId    String?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter      Encounter?   @relation(fields: [encounterId], references: [id])

  @@index([patientId, kind])
  @@index([organizationId, needsReview])
}

// --------------------------------------------------------------
// Encounters & Notes
// --------------------------------------------------------------

enum EncounterStatus {
  scheduled
  in_progress
  complete
  cancelled
}

model Encounter {
  id             String          @id @default(cuid())
  organizationId String
  patientId      String
  providerId     String?
  status         EncounterStatus @default(scheduled)
  scheduledFor   DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  modality       String          @default("in_person") // in_person | video | phone
  reason         String?
  briefingContext Json?           // Pre-visit intelligence briefing (talking points, risk flags, summary)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient        Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  provider       Provider?       @relation(fields: [providerId], references: [id], onDelete: SetNull)
  notes          Note[]
  documents      Document[]
  claims         Claim[]

  @@index([patientId, status])
  @@index([providerId, scheduledFor])
  @@index([organizationId, status, createdAt])
}

enum NoteStatus {
  draft
  needs_review
  finalized
  amended
}

model Note {
  id             String     @id @default(cuid())
  encounterId    String
  authorUserId   String?    // null when drafted by agent, set when finalized by clinician
  status         NoteStatus @default(draft)
  // Structured note blocks — see src/lib/domain/notes.ts for the canonical block types.
  blocks         Json
  narrative      String?    // free-form fallback text
  aiDrafted      Boolean    @default(false)
  aiConfidence   Float?
  finalizedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  encounter      Encounter  @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  codingSuggestion CodingSuggestion?

  @@index([encounterId, status])
}

model CodingSuggestion {
  id             String   @id @default(cuid())
  noteId         String   @unique
  icd10          Json     // [{ code, label, confidence }]
  emLevel        String?
  rationale      String?
  generatedAt    DateTime @default(now())

  note           Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------------
// Billing — Claims, Payments, Fee Schedule
// --------------------------------------------------------------

enum ClaimStatus {
  draft          // not yet submitted
  submitted      // sent to payer
  pending        // payer processing
  paid           // fully paid
  partial        // partially paid, balance due
  denied         // payer denied
  appealed       // under appeal
  written_off    // written off
}

model Claim {
  id              String       @id @default(cuid())
  organizationId  String
  patientId       String
  encounterId     String?
  providerId      String?
  status          ClaimStatus  @default(draft)
  // Coding
  cptCodes        Json         // [{ code, label, units, chargeAmount }]
  icd10Codes      Json         // [{ code, label }]
  // Financials (in cents to avoid float rounding)
  billedAmountCents   Int
  allowedAmountCents  Int?
  paidAmountCents     Int       @default(0)
  patientRespCents    Int       @default(0)
  // Payer
  payerName       String?       // "Blue Cross Blue Shield", "Aetna", etc.
  payerId         String?       // payer's claim id
  claimNumber     String?       // our internal claim number
  // Lifecycle
  serviceDate     DateTime
  submittedAt     DateTime?
  paidAt          DateTime?
  deniedAt        DateTime?
  denialReason    String?
  notes           String?
  // Agent-written: scrub issues from Charge Integrity Agent
  scrubIssues     Json?
  scrubbedAt      DateTime?
  // Agent-written: denial triage from Denial Triage Agent
  denialTriage    Json?
  triagedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient         Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter       Encounter?    @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  provider        Provider?     @relation(fields: [providerId], references: [id], onDelete: SetNull)
  payments        Payment[]
  financialEvents FinancialEvent[]

  @@index([organizationId, status, serviceDate])
  @@index([patientId, serviceDate])
  @@index([providerId, serviceDate])
}

enum PaymentSource {
  patient
  insurance
  adjustment
}

model Payment {
  id              String         @id @default(cuid())
  claimId         String
  source          PaymentSource
  amountCents     Int
  paymentDate     DateTime       @default(now())
  reference       String?        // check #, EFT trace, last4 of card
  notes           String?

  claim           Claim          @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId, paymentDate])
}

model FeeScheduleEntry {
  id              String        @id @default(cuid())
  organizationId  String
  cptCode         String
  description     String
  defaultChargeCents Int
  category        String?        // "E&M", "Procedure", "Cannabis Counseling", etc.
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())

  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, cptCode])
  @@index([organizationId, category])
}

// --------------------------------------------------------------
// Ledger, Statements, Payment Plans, Coverage
// --------------------------------------------------------------

enum FinancialEventType {
  charge_created
  charge_voided
  copay_assessed
  copay_collected
  claim_submitted
  claim_accepted
  claim_denied
  insurance_paid
  contractual_adjustment
  patient_responsibility_transferred
  patient_payment
  refund_issued
  credit_applied
  statement_issued
  statement_viewed
  payment_plan_created
  payment_plan_installment
  write_off
  chargeback
}

/// Every money-affecting event lands here as an immutable row.
/// amountCents is SIGNED: positive = money into practice, negative = money out/owed.
/// This is the source of truth for all balance calculations.
model FinancialEvent {
  id              String              @id @default(cuid())
  organizationId  String
  patientId       String
  claimId         String?
  encounterId     String?
  paymentId       String?
  type            FinancialEventType
  amountCents     Int                  // signed; + = cash in, - = cash out / balance owed
  description     String
  metadata        Json?                // payer, CPT, confidence, agent id, etc.
  occurredAt      DateTime             @default(now())
  createdByUserId String?              // null when system/agent
  createdByAgent  String?              // agent name if automated

  patient         Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  claim           Claim?               @relation(fields: [claimId], references: [id], onDelete: SetNull)

  @@index([patientId, occurredAt])
  @@index([organizationId, occurredAt])
  @@index([claimId])
}

enum StatementStatus {
  draft
  sent
  viewed
  partially_paid
  paid
  overdue
  disputed
  voided
}

model Statement {
  id                 String          @id @default(cuid())
  organizationId     String
  patientId          String
  statementNumber    String          @unique
  periodStart        DateTime
  periodEnd          DateTime
  dueDate            DateTime
  totalChargesCents  Int
  insurancePaidCents Int             @default(0)
  adjustmentsCents   Int             @default(0)
  priorBalanceCents  Int             @default(0)
  amountDueCents     Int
  paidToDateCents    Int             @default(0)
  status             StatementStatus @default(draft)
  deliveryMethod     String          @default("portal") // portal | email | sms | mail
  sentAt             DateTime?
  viewedAt           DateTime?
  paidAt             DateTime?
  lineItems          Json            // array of { description, amountCents, encounterId, cptCode }
  plainLanguageSummary String?       // AI-generated explanation
  createdAt          DateTime        @default(now())

  patient            Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, status])
  @@index([organizationId, status, dueDate])
}

enum PaymentPlanStatus {
  active
  completed
  cancelled
  defaulted
  paused
}

model PaymentPlan {
  id                      String             @id @default(cuid())
  organizationId          String
  patientId               String
  totalAmountCents        Int
  installmentAmountCents  Int
  frequency               String             // monthly | biweekly | weekly
  numberOfInstallments    Int
  installmentsPaid        Int                @default(0)
  startDate               DateTime
  nextPaymentDate         DateTime?
  status                  PaymentPlanStatus  @default(active)
  paidAmountCents         Int                @default(0)
  autopayEnabled          Boolean            @default(false)
  notes                   String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  patient                 Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, status])
}

enum CoverageType {
  primary
  secondary
  tertiary
  self_pay
}

enum EligibilityStatus {
  active
  inactive
  pending_verification
  termed
  unknown
}

model PatientCoverage {
  id                      String             @id @default(cuid())
  patientId               String
  type                    CoverageType       @default(primary)
  payerName               String             // "Blue Cross Blue Shield"
  payerId                 String?
  memberId                String
  groupNumber             String?
  planName                String?
  subscriberName          String?
  relationshipToSubscriber String?           // self | spouse | child | other
  effectiveDate           DateTime?
  terminationDate         DateTime?
  eligibilityStatus       EligibilityStatus  @default(unknown)
  eligibilityLastCheckedAt DateTime?
  copayCents              Int?               // default visit copay estimate
  deductibleCents         Int?               // annual deductible
  deductibleMetCents      Int                @default(0)
  outOfPocketMaxCents     Int?
  outOfPocketMetCents     Int                @default(0)
  coinsurancePct          Int?               // e.g. 20 for 20%
  notes                   String?
  active                  Boolean            @default(true)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  patient                 Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, type, active])
}

enum StoredPaymentMethodType {
  card
  ach
}

model StoredPaymentMethod {
  id              String                   @id @default(cuid())
  patientId       String
  type            StoredPaymentMethodType
  last4           String                   // "4242" — never store full PAN
  brand           String?                  // visa | mastercard | amex | bank name
  expiryMonth     Int?
  expiryYear      Int?
  isDefault       Boolean                  @default(false)
  tokenReference  String                   // opaque token from processor (Payabli)
  consentedAt     DateTime                 @default(now())
  active          Boolean                  @default(true)
  createdAt       DateTime                 @default(now())

  patient         Patient                  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, active])
}

// --------------------------------------------------------------
// Assessments & Outcomes
// --------------------------------------------------------------

model Assessment {
  id             String   @id @default(cuid())
  slug           String   @unique // "phq-9", "gad-7", "pain-vas"
  title          String
  description    String?
  // Form schema — see src/lib/domain/assessments.ts
  schema         Json
  scoringRules   Json?
  createdAt      DateTime @default(now())

  responses      AssessmentResponse[]
}

model AssessmentResponse {
  id             String   @id @default(cuid())
  assessmentId   String
  patientId      String
  answers        Json
  score          Float?
  interpretation String?
  submittedAt    DateTime @default(now())

  assessment     Assessment @relation(fields: [assessmentId], references: [id])
  patient        Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, submittedAt])
}

enum OutcomeMetric {
  pain
  sleep
  anxiety
  mood
  nausea
  appetite
  energy
  adherence
  side_effects
}

model OutcomeLog {
  id             String        @id @default(cuid())
  patientId      String
  metric         OutcomeMetric
  value          Float         // normalized 0-10
  note           String?
  loggedAt       DateTime      @default(now())

  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, metric, loggedAt])
}

// --------------------------------------------------------------
// Messaging
// --------------------------------------------------------------

model MessageThread {
  id             String    @id @default(cuid())
  patientId      String
  subject        String
  lastMessageAt  DateTime  @default(now())
  createdAt      DateTime  @default(now())

  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@index([patientId, lastMessageAt])
}

enum MessageStatus {
  draft
  sent
  read
}

model Message {
  id             String        @id @default(cuid())
  threadId       String
  senderUserId   String?       // null when agent-drafted
  senderAgent    String?       // agent name:version if AI-drafted
  status         MessageStatus @default(draft)
  body           String
  aiDrafted      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  sentAt         DateTime?

  thread         MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender         User?         @relation("MessageSender", fields: [senderUserId], references: [id])

  @@index([threadId, createdAt])
}

// --------------------------------------------------------------
// Scheduling
// --------------------------------------------------------------

enum AppointmentStatus {
  requested
  confirmed
  cancelled
  completed
  no_show
}

model Appointment {
  id             String            @id @default(cuid())
  patientId      String
  providerId     String?
  status         AppointmentStatus @default(requested)
  startAt        DateTime
  endAt          DateTime
  modality       String            @default("video")
  notes          String?
  createdAt      DateTime          @default(now())

  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  provider       Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([providerId, startAt])
  @@index([patientId, startAt])
}

// --------------------------------------------------------------
// Tasks (human or agent-owned work items)
// --------------------------------------------------------------

enum TaskStatus {
  open
  in_progress
  done
  snoozed
  cancelled
}

model Task {
  id             String     @id @default(cuid())
  organizationId String
  patientId      String?
  title          String
  description    String?
  status         TaskStatus @default(open)
  assigneeRole   Role?
  assigneeUserId String?
  dueAt          DateTime?
  createdAt      DateTime   @default(now())
  completedAt    DateTime?

  patient        Patient?   @relation(fields: [patientId], references: [id])

  @@index([organizationId, status])
  @@index([assigneeUserId, status])
}

// --------------------------------------------------------------
// Orchestration queue
// --------------------------------------------------------------

enum AgentJobStatus {
  pending
  claimed
  running
  needs_approval
  succeeded
  failed
  cancelled
}

model AgentJob {
  id             String         @id @default(cuid())
  organizationId String?
  workflowName   String
  agentName      String
  eventName      String
  input          Json
  output         Json?
  status         AgentJobStatus @default(pending)
  attempts       Int            @default(0)
  maxAttempts    Int            @default(3)
  lastError      String?
  logs           Json           @default("[]")
  requiresApproval Boolean      @default(false)
  approvalRequiredAt DateTime?
  approvedById   String?
  approvedAt     DateTime?
  claimedAt      DateTime?
  claimedBy      String?        // worker id
  runAfter       DateTime       @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime       @default(now())

  organization   Organization?  @relation(fields: [organizationId], references: [id])
  approvedBy     User?          @relation("JobApprovedBy", fields: [approvedById], references: [id])

  @@index([status, runAfter])
  @@index([organizationId, status])
  @@index([workflowName, status])
}

// --------------------------------------------------------------
// Audit log (append-only)
// --------------------------------------------------------------

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  actorUserId    String?
  actorAgent     String?  // "agent:scribe@1.0.0"
  action         String   // e.g. "patient.read", "note.finalized"
  subjectType    String?
  subjectId      String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization   Organization? @relation(fields: [organizationId], references: [id])
  actor          User?         @relation(fields: [actorUserId], references: [id])

  @@index([organizationId, createdAt])
  @@index([subjectType, subjectId])
}

// --------------------------------------------------------------
// Cannabis Prescribing / Dosing
// --------------------------------------------------------------

enum ProductType {
  oil
  tincture
  capsule
  flower
  vape_cartridge
  edible
  topical
  suppository
  spray
  other
}

enum DeliveryRoute {
  oral
  sublingual
  inhalation
  topical
  rectal
  vaginal
}

model CannabisProduct {
  id                String      @id @default(cuid())
  organizationId    String
  name              String        // e.g. "THC Infused Oil 10mg/mL"
  brand             String?       // e.g. "Green Path Organics"
  productType       ProductType
  route             DeliveryRoute
  // Cannabinoid concentrations (mg per mL, mg per unit, or % for flower)
  thcConcentration  Float?        // mg/mL for liquids, mg/unit for capsules, % for flower
  cbdConcentration  Float?
  cbnConcentration  Float?
  cbgConcentration  Float?
  thcCbdRatio       String?       // e.g. "1:1", "20:1", "1:20"
  // Terpene profile (optional, structured)
  terpeneProfile    Json?         // { myrcene: 0.5, limonene: 0.3, ... } in %
  // Units
  concentrationUnit String       @default("mg/mL") // "mg/mL", "mg/unit", "%", "mg/g"
  unitSize          Float?        // mL per bottle, units per pack, grams per container
  // Metadata
  description       String?
  active            Boolean       @default(true)
  createdAt         DateTime      @default(now())

  organization      Organization  @relation(fields: [organizationId], references: [id])
  regimens          DosingRegimen[]

  @@index([organizationId, active])
}

model DosingRegimen {
  id                String      @id @default(cuid())
  patientId         String
  productId         String
  prescribedById    String?     // provider user id
  // Dosing
  volumePerDose     Float       // mL, puffs, units, mg
  volumeUnit        String      @default("mL") // "mL", "puffs", "units", "mg", "drops"
  frequencyPerDay   Int         @default(1)
  timingInstructions String?    // e.g. "1 hour before bed", "after meals"
  // Auto-calculated mg (from product concentration * volume)
  calculatedThcMgPerDose  Float?
  calculatedCbdMgPerDose  Float?
  calculatedThcMgPerDay   Float?
  calculatedCbdMgPerDay   Float?
  // Duration
  startDate         DateTime    @default(now())
  endDate           DateTime?
  active            Boolean     @default(true)
  // Patient-facing instructions
  patientInstructions String?   // "Take 0.25 mL under the tongue twice daily"
  // Clinician notes
  clinicianNotes    String?
  // EMR-088: contraindication override — populated when prescribing despite
  // a flagged contraindication. Contains: { contraindicationIds, reason,
  // overriddenByUserId, overriddenAt }
  contraindicationOverride Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  patient           Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  product           CannabisProduct @relation(fields: [productId], references: [id])
  doseLogs          DoseLog[]

  @@index([patientId, active])
}

model DoseLog {
  id                String      @id @default(cuid())
  patientId         String
  regimenId         String?
  // What was taken
  actualVolume      Float       // what they actually took
  volumeUnit        String      @default("mL")
  estimatedThcMg    Float?      // auto-calculated from regimen product
  estimatedCbdMg    Float?
  route             DeliveryRoute?
  // Context
  note              String?
  loggedAt          DateTime    @default(now())

  patient           Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  regimen           DosingRegimen? @relation(fields: [regimenId], references: [id])

  @@index([patientId, loggedAt])
}

// --------------------------------------------------------------
// Conventional Medications & Supplements
// --------------------------------------------------------------

enum MedicationType {
  prescription
  otc
  supplement
  cannabis
}

model PatientMedication {
  id              String         @id @default(cuid())
  patientId       String
  name            String         // "Warfarin", "Melatonin", "Vitamin D"
  genericName     String?        // "warfarin sodium"
  type            MedicationType
  dosage          String?        // "5mg daily"
  prescriber      String?        // who prescribed it (external)
  active          Boolean        @default(true)
  startDate       DateTime?
  notes           String?
  createdAt       DateTime       @default(now())

  patient         Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, active])
}

// --------------------------------------------------------------
// Research (stubbed for V1)
// --------------------------------------------------------------

model ResearchQuery {
  id             String   @id @default(cuid())
  userId         String?
  patientId      String?
  queryText      String
  createdAt      DateTime @default(now())

  results        ResearchResult[]

  @@index([userId, createdAt])
}

model ResearchResult {
  id             String   @id @default(cuid())
  queryId        String
  title          String
  source         String
  year           Int?
  summary        String
  citation       String
  quantitativeFindings Json?
  rank           Int      @default(0)

  query          ResearchQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------------
// Practice launch readiness
// --------------------------------------------------------------

model PracticeLaunchStatus {
  id             String   @id @default(cuid())
  organizationId String   @unique
  readinessScore Int      @default(0)
  blockers       Json     @default("[]")
  nextSteps      Json     @default("[]")
  goLiveAt       DateTime?
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
