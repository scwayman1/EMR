// Canonical data model for the AI-Native Cannabis Care Platform.
//
// Design rules:
//   1. Favor structured columns; fall back to JSONB only when the shape
//      is genuinely open (note blocks, intake answers, agent payloads).
//   2. Every sensitive action writes an AuditLog row.
//   3. Every async operation goes through AgentJob — one queue to rule them all.
//   4. Soft-delete by default for patient-owned data via `deletedAt`.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  // Runtime query URL — points at Supabase's PgBouncer pooler (port 6543).
  url       = env("DATABASE_URL")
  // Schema-change URL — direct connection (port 5432). Prisma uses this
  // for `migrate deploy` / `db push` / `introspect` because those need
  // advisory locks that PgBouncer drops. Falls back to `url` if unset
  // locally; prod MUST have this set.
  directUrl = env("DIRECT_URL")
}

