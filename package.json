{
  "name": "cannabis-care-platform",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Native Cannabis Care Platform — unified patient portal, clinician EMR, and agent orchestration layer.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "worker": "tsx src/workers/agent-worker.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-cfo": "tsx scripts/seed-cfo.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "tsx scripts/smoke-test.ts",
    "pm": "tsx scripts/pm-agent.ts",
    "manifests:lint": "tsx scripts/lint-manifests.ts",
    "audit:export": "tsx scripts/export-audit-log.ts",
    "lint:modality": "tsx scripts/lint-modality-bleed.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.1",
    "@daily-co/daily-js": "^0.86.0",
    "@prisma/adapter-pg": "^5.22.0",
    "@prisma/client": "^5.18.0",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/supabase-js": "^2.103.3",
    "@types/node": "^20.14.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "^10.4.19",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "next": "^14.2.35",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "postcss": "^8.4.39",
    "prisma": "^5.18.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "svix": "^1.90.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.20.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "pino-pretty": "^13.1.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
